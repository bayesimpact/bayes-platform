---
import { DEFAULT_LOCALE, LOCALES } from "@/consts"

// Root entry point. Statically renders a redirect to the default locale and
// upgrades to the user's preferred language on the client when possible.
const target = `/${DEFAULT_LOCALE}`
const locales = JSON.stringify(LOCALES)
---

<!doctype html>
<html lang={DEFAULT_LOCALE}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Bayes Platform Help Center</title>
    <script is:inline define:vars={{ locales, target }}>
      const supported = JSON.parse(locales)
      const preferred = (navigator.language || "en").slice(0, 2).toLowerCase()
      const dest = supported.includes(preferred) ? `/${preferred}` : target
      window.location.replace(dest)
    </script>
  </head>
  <body>
    <p>Redirecting to <a href={target}>the help center</a>…</p>
  </body>
</html>
