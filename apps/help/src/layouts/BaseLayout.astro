---
import Footer from "@/components/Footer.astro"
import Header from "@/components/Header.astro"
import { BRAND_LOGO_COLOR, BRAND_PRIMARY, DEFAULT_LOCALE, type Locale, SITE_TITLE } from "@/consts"
import { useTranslations } from "@/i18n/ui"
import "@/styles/global.css"

interface Props {
  title: string
  description?: string
  locale?: Locale
  showMenuToggle?: boolean
}

const { title, description, locale = DEFAULT_LOCALE, showMenuToggle = false } = Astro.props
const t = useTranslations(locale)
const fullTitle = title === SITE_TITLE ? title : `${title} · ${SITE_TITLE}`
const metaDescription = description ?? t("site.tagline")
const appUrl = import.meta.env.PUBLIC_APP_URL as string | undefined
const canonical = new URL(Astro.url.pathname, Astro.site).toString()
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Per-tenant brand theme (build-time). Drives the walkthrough animations so they
        match the platform that opened this help center. Defaults to coral. */}
    <style set:html={`:root{--brand-primary:${BRAND_PRIMARY};--brand-logo-color:${BRAND_LOGO_COLOR};}`}></style>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {/* Bayes brand fonts — Inter (body), Archivo Black (display), Kaisei Decol (serif). */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700;800&family=Kaisei+Decol:wght@700&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="min-h-screen">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-3 focus:py-2 focus:text-primary-foreground"
    >
      Skip to content
    </a>
    <Header appUrl={appUrl} showMenuToggle={showMenuToggle} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
