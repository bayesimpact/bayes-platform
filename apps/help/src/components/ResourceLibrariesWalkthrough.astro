<script define:vars={{ steps, labels }}>
  const cs = document.currentScript
  const rlw =
    cs && cs.previousElementSibling && cs.previousElementSibling.classList.contains("rlw")
      ? cs.previousElementSibling
      : document.querySelector(".rlw")
  const q = (sel) => rlw.querySelector(sel)
  const pages = [...rlw.querySelectorAll(".page")]
  const dotsWrap = rlw.querySelector("[data-dots]")
  const bar = rlw.querySelector("[data-bar]")
  const crumb = rlw.querySelector("#crumb")
  const crumbText = rlw.querySelector(".crumb-text")
  const capText = rlw.querySelector("[data-captext]")
  const stepCount = rlw.querySelector("[data-stepcount]")
  const playPause = rlw.querySelector("[data-playpause]")
  const prevBtn = rlw.querySelector("[data-prev]")
  const nextBtn = rlw.querySelector("[data-next]")
  const navSources = rlw.querySelector("#navSources")
  const sourcesSub = rlw.querySelector("#sourcesSub")
  const newchat = rlw.querySelector("#newchat")
  const DUR = 6000
  let idx = 0, playing = true, timer = null

  steps.forEach((_, i) => {
    const b = document.createElement("button")
    b.className = "dotnav"; b.setAttribute("role", "tab"); b.setAttribute("aria-label", labels.step + " " + (i + 1))
    b.addEventListener("click", () => go(i)); dotsWrap.appendChild(b)
  })
  const dots = [...dotsWrap.children]

  function clearMarks() {
    rlw.querySelectorAll(".spot-on").forEach((el) => el.classList.remove("spot-on"))
    rlw.querySelectorAll(".observe-on").forEach((el) => el.classList.remove("observe-on"))
  }
  function typeInto(el, text, speed = 55) {
    if (!el) return
    el.textContent = ""; el.classList.add("caret")
    let i = 0
    const tick = () => {
      if (!playing || el.dataset.stop === "1") return
      el.textContent = text.slice(0, i++)
      if (i <= text.length) setTimeout(tick, speed); else el.classList.remove("caret")
    }
    setTimeout(tick, 550)
  }
  function render() {
    const step = steps[idx]
    pages.forEach((p) => p.setAttribute("data-active", String(p.dataset.page === step.page)))
    dots.forEach((d, i) => d.classList.toggle("on", i === idx))
    stepCount.textContent = labels.step + " " + (idx + 1) + " / " + steps.length
    capText.textContent = step.text
    if (step.crumb) {
      crumb.style.display = ""
      crumbText.textContent = step.crumb
    } else {
      crumb.style.display = "none"
    }
    navSources.classList.toggle("open", step.sources)
    sourcesSub.classList.toggle("open", step.sources)
    q("#agent1").classList.toggle("on", step.nav === "agent1")
    q("#navLibraries").classList.toggle("on", step.nav === "navLibraries")
    newchat.style.display = step.nav === "agent1" ? "flex" : "none"

    clearMarks()
    const active = idx
    setTimeout(() => {
      if (active !== idx) return
      if (step.spot) q("#" + step.spot)?.classList.add("spot-on")
      step.observe.forEach((id) => q("#" + id)?.classList.add("observe-on"))
    }, 260)

    rlw.querySelectorAll("[id^=type]").forEach((el) => (el.dataset.stop = "1"))
    if (step.type) {
      const el = q("#" + step.type[0])
      if (el) { el.dataset.stop = "0"; typeInto(el, step.type[1]) }
    }
    bar.classList.remove("run"); void bar.offsetWidth
    bar.style.setProperty("--dur", DUR + "ms")
    if (playing) bar.classList.add("run")
  }
  function schedule() { clearTimeout(timer); if (playing) timer = setTimeout(() => go(idx + 1), DUR) }
  function go(n) { idx = (n + steps.length) % steps.length; render(); schedule() }
  function setPlaying(p) {
    playing = p; playPause.textContent = p ? "⏸" : "▶"
    if (p) { bar.classList.add("run"); schedule() } else { clearTimeout(timer); bar.classList.remove("run") }
  }
  prevBtn.addEventListener("click", () => go(idx - 1))
  nextBtn.addEventListener("click", () => go(idx + 1))
  playPause.addEventListener("click", () => setPlaying(!playing))

  render(); schedule()
</script>

