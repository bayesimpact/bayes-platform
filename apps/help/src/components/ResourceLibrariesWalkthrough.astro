---
/**
 * Animated, full-page walkthrough of the Resource libraries flow, rebuilt to
 * mirror the real Studio interface (sidebar + inset layout, exact labels and
 * colours). The whole platform page stays visible at every step — the content
 * pane, the active sidebar item and the highlighted click target change per
 * step. Reusable: pass `lang="fr"` for the French copy.
 *
 * Tokens are declared locally on `.rlw` so the widget renders correctly
 * regardless of the host page.
 */
type Lang = "en" | "fr"
const { lang = "en" } = Astro.props as { lang?: Lang }

const STRINGS = {
  en: {
    org: "Bayes Impact Demo", studio: "Studio", agents: "Agents", newChat: "New Chat",
    agent1: "Bayes Assistant", conversationAgent: "Conversation Agent", extractionAgent: "Extraction Agent", formAgent: "Form Agent",
    settingsName: "Demo", settings: "Settings", evaluations: "Evaluations", analytics: "Analytics", sources: "Sources",
    documents: "Documents", webSources: "Web sources", resourceLibraries: "Resource libraries", members: "Members", admin: "Admin",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    conversation: "Conversation", evaluation: "Evaluation", app: "App", edit: "Edit",
    newChatDesc: "Start a chat with your agent.", create: "Create",
    analyticsDesc: "Conversation metrics for this agent.", feedback: "Feedback", feedbackDesc: "Manage feedback on agent messages.",
    rlTitle: "Resource libraries", rlDesc: "Group resources the assistant can surface to users.",
    newLibrary: "New library",
    empty: "No resource libraries yet. Create one to let this workspace's agents surface resources.",
    newResourceLibrary: "New resource library", title: "Title", libName: "Getting started",
    count0: "0 resources", save: "Save", add: "Add", resources: "Resources", noResources: "No resources yet.",
    newResource: "New resource", resName: "Quick start guide", description: "Description", descVal: "The basics to get up and running.",
    matchingHints: "Matching hints", notShown: "(not shown to users)",
    hintsPlaceholder: 'Keywords, synonyms, or "use when…" guidance the assistant uses to match user requests',
    url: "URL", uploadedFile: "Uploaded file", dragUpload: "Drag or upload a file", fileName: "quickstart.pdf", cancel: "Cancel",
    charsTitle: "17 / 200 characters", charsDesc: "33 / 2000 characters", charsHints: "0 / 1000 characters",
    colTitle: "Title", colDesc: "Description", colLink: "Link", resLink: "quickstart.pdf",
    tabGeneral: "General", tabModel: "Model", tabOutput: "Output", tabSources: "Sources", tabResources: "Resources",
    tabCategories: "Conversation categories", tabEmbed: "Embed",
    rlFieldLabel: "Resource libraries", manage: "Manage libraries",
    agentTabDesc: "The assistant can surface resources from the selected libraries when a user's request matches a resource's title or description.",
    addLibrary: "Add library", update: "Update",
    userMsg: "How do I get started?", aiMsg: "Sure! Here's a resource that should help you get going:",
    prev: "Prev", next: "Next", step: "Step",
    steps: [
      "Open the Sources section from the left menu.",
      "Select Resource libraries.",
      "Click New library.",
      "Title your library, then click Create.",
      "Click the arrow to open your library.",
      "Click Add to create a resource.",
      "Fill Title, Description, Matching hints and a URL or file, then click Create.",
      "Preview, Edit or Delete a resource from the ⋯ menu. Add as many as you like.",
      "Attach the library to an agent: open the Resources tab → Add library, then Update.",
      "When a message matches, the assistant surfaces the resource as a card.",
    ],
  },
  fr: {
    org: "Bayes Impact Demo", studio: "Studio", agents: "Agents", newChat: "Nouvelle discussion",
    agent1: "Bayes Assistant", conversationAgent: "Conversation Agent", extractionAgent: "Extraction Agent", formAgent: "Form Agent",
    settingsName: "Demo", settings: "Paramètres", evaluations: "Évaluations", analytics: "Analytique", sources: "Sources",
    documents: "Documents", webSources: "Sites web", resourceLibraries: "Bibliothèques de ressources", members: "Membres", admin: "Admin",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    conversation: "Conversation", evaluation: "Évaluation", app: "App", edit: "Modifier",
    newChatDesc: "Démarrez une discussion avec votre agent.", create: "Créer",
    analyticsDesc: "Indicateurs de conversation pour cet agent.", feedback: "Retours utilisateurs", feedbackDesc: "Gérez les retours sur les messages de l'agent.",
    rlTitle: "Bibliothèques de ressources", rlDesc: "Regroupez les ressources que l'assistant peut proposer aux utilisateurs.",
    newLibrary: "Nouvelle bibliothèque",
    empty: "Aucune bibliothèque de ressources pour le moment. Créez-en une pour permettre aux agents de cet espace de travail de proposer des ressources.",
    newResourceLibrary: "Nouvelle bibliothèque de ressources", title: "Titre", libName: "Pour commencer",
    count0: "0 ressource", save: "Enregistrer", add: "Ajouter", resources: "Ressources", noResources: "Aucune ressource pour le moment.",
    newResource: "Nouvelle ressource", resName: "Guide de démarrage", description: "Description", descVal: "Les bases pour prendre l'application en main.",
    matchingHints: "Indices de correspondance", notShown: "(non affichés aux utilisateurs)",
    hintsPlaceholder: "Mots-clés, synonymes ou indications « à utiliser quand… » que l'assistant utilise pour faire correspondre les demandes",
    url: "URL", uploadedFile: "Fichier téléversé", dragUpload: "Glissez ou téléversez un fichier", fileName: "guide-demarrage.pdf", cancel: "Annuler",
    charsTitle: "17 / 200 caractères", charsDesc: "36 / 2000 caractères", charsHints: "0 / 1000 caractères",
    colTitle: "Titre", colDesc: "Description", colLink: "Lien", resLink: "guide-demarrage.pdf",
    tabGeneral: "Général", tabModel: "Modèle", tabOutput: "Sortie", tabSources: "Sources", tabResources: "Resources",
    tabCategories: "Catégories de conversation", tabEmbed: "Intégration",
    rlFieldLabel: "Bibliothèques de ressources", manage: "Gérer les bibliothèques",
    agentTabDesc: "L'assistant peut proposer des ressources des bibliothèques sélectionnées lorsqu'une demande de l'utilisateur correspond au titre ou à la description d'une ressource.",
    addLibrary: "Add library", update: "Mettre à jour",
    userMsg: "Comment je commence ?", aiMsg: "Bien sûr ! Voici une ressource qui devrait vous aider à démarrer :",
    prev: "Précédent", next: "Suivant", step: "Étape",
    steps: [
      "Ouvrez la section Sources dans le menu de gauche.",
      "Sélectionnez Bibliothèques de ressources.",
      "Cliquez sur Nouvelle bibliothèque.",
      "Donnez un titre à votre bibliothèque, puis cliquez sur Créer.",
      "Cliquez sur la flèche pour ouvrir votre bibliothèque.",
      "Cliquez sur Ajouter pour créer une ressource.",
      "Remplissez Titre, Description, Indices de correspondance et une URL ou un fichier, puis cliquez sur Créer.",
      "Prévisualisez, modifiez ou supprimez une ressource depuis le menu ⋯. Ajoutez-en autant que vous voulez.",
      "Rattachez la bibliothèque à un agent : onglet Resources → Add library, puis Mettre à jour.",
      "Quand un message correspond, l'assistant propose la ressource sous forme de carte.",
    ],
  },
} as const

const s = STRINGS[lang]

// Step config consumed by the client script (captions come from `s.steps`).
const steps = [
  { page: "agent", crumb: s.agent1, sources: false, nav: "agent1", spot: "navSources", observe: [] },
  { page: "agent", crumb: s.agent1, sources: true, nav: "agent1", spot: "navLibraries", observe: [] },
  { page: "librariesEmpty", crumb: "", sources: true, nav: "navLibraries", spot: "btnNewLibrary", observe: [] },
  { page: "newLibrary", crumb: "", sources: true, nav: "navLibraries", spot: "btnCreateLibrary", observe: ["obsLibTitle"], type: ["typeLib", s.libName] },
  { page: "librariesList", crumb: "", sources: true, nav: "navLibraries", spot: "cardArrow", observe: [] },
  { page: "libraryEmpty", crumb: "", sources: true, nav: "navLibraries", spot: "btnAdd", observe: [] },
  { page: "newResource", crumb: "", sources: true, nav: "navLibraries", spot: "btnCreateResource", observe: ["obsResourceFields"], type: ["typeRes", s.resName] },
  { page: "libraryTable", crumb: "", sources: true, nav: "navLibraries", spot: "rowDots", observe: [] },
  { page: "agentEditor", crumb: s.agent1, sources: false, nav: "agent1", spot: "btnAddLibrary", observe: ["obsTag"] },
  { page: "chat", crumb: s.agent1, sources: false, nav: "agent1", spot: "", observe: ["obsCard"] },
].map((step, i) => ({ ...step, text: s.steps[i] }))

const labels = { prev: s.prev, next: s.next, step: s.step }
---

<div class="rlw" role="group" aria-label={s.rlTitle}>
  <div class="shell">
    <!-- Sidebar -->
    <aside class="sb">
      <div class="sb-head">
        <span class="logo"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 410.85 405.35" aria-hidden="true"><path d="M366.77,161.43H247V41.61a41.37,41.37,0,1,0-82.74,0V161.43H44.39a41.37,41.37,0,0,0,0,82.74H164.21V364A41.37,41.37,0,1,0,247,364V244.17H366.77a41.37,41.37,0,1,0,0-82.74Z"/><circle cx="205.58" cy="364.27" r="41.05"/><circle cx="369.79" cy="202.64" r="41.05"/><circle cx="41.05" cy="202.64" r="41.05"/><circle cx="205.58" cy="41.05" r="41.05"/><circle cx="205.58" cy="202.64" r="41.05"/></svg></span>
        <span class="org"><b>{s.org}</b><small>{s.studio}</small></span>
      </div>
      <div class="sb-scroll">
        <div class="grp-label">{s.agents}<span class="add"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg></span></div>
        <div class="navitem" id="agent1"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg><span>{s.agent1}</span></div>
        <div class="newchat" id="newchat"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg> {s.newChat}</div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg><span>{s.conversationAgent}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 8h8"/><path d="M7 12h10"/><path d="M7 16h6"/></svg><span>{s.extractionAgent}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M4 14h6"/><path d="M4 2h10"/><rect x="4" y="18" width="16" height="4" rx="1"/><rect x="4" y="6" width="16" height="4" rx="1"/></svg><span>{s.formAgent}</span></div>

        <div class="grp-label stack"><span class="name">{s.settingsName}</span><span>{s.settings}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/></svg><span>{s.evaluations}</span><svg class="chev" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg><span>{s.analytics}</span></div>
        <div class="navitem" id="navSources"><svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 15 21.84"/><path d="M21 5V8"/><path d="M21 12L18 17H22L19 22"/><path d="M3 12A9 3 0 0 0 14.59 14.87"/></svg><span>{s.sources}</span><svg class="chev" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></div>
        <div class="subwrap" id="sourcesSub">
          <div class="subitem"><svg viewBox="0 0 24 24"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg><span>{s.documents}</span></div>
          <div class="subitem"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg><span>{s.webSources}</span></div>
          <div class="subitem" id="navLibraries"><svg viewBox="0 0 24 24"><rect width="8" height="18" x="3" y="3" rx="1"/><path d="M7 3v18"/><path d="M20.4 18.9c.2.5-.1 1.1-.6 1.3l-1.9.7c-.5.2-1.1-.1-1.3-.6L11.1 5.1c-.2-.5.1-1.1.6-1.3l1.9-.7c.5-.2 1.1.1 1.3.6Z"/></svg><span>{s.resourceLibraries}</span></div>
        </div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg><span>{s.members}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg><span>{s.admin}</span></div>
      </div>
      <div class="sb-user">
        <span class="avatar">AM</span>
        <span class="who"><b>{s.userName}</b><small>{s.userEmail}</small></span>
        <span class="updown"><svg viewBox="0 0 24 24"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg></span>
      </div>
    </aside>

    <!-- Main inset -->
    <div class="inset">
      <div class="topbar">
        <span class="trig"><svg viewBox="0 0 24 24"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg></span>
        <span class="crumb" id="crumb">
          <svg class="crumb-ico" viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg>
          <span class="crumb-text"></span>
        </span>
      </div>
      <div class="canvas">
        <span class="fab"><svg viewBox="0 0 24 24"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg></span>

        <!-- agent overview -->
        <div class="page" data-page="agent" data-active="true">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.agent1}</span><span class="sub"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg> {s.conversation}</span></span>
            <span class="right">
              <span class="toolbtn"><svg viewBox="0 0 24 24"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg> {s.evaluation}</span>
              <span class="toolbtn"><svg viewBox="0 0 24 24"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg> {s.app}</span>
              <span class="toolbtn"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg> {s.members}</span>
              <span class="toolbtn"><svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg> {s.edit}</span>
              <span class="toolbtn icononly"><svg viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="m19 6-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg></span>
            </span>
          </div>
          <div class="cards3">
            <div class="ecard"><b>{s.newChat}</b><p>{s.newChatDesc}</p><span class="btn sm">{s.create} <svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg></span></div>
            <div class="ecard"><b>{s.analytics}</b><p>{s.analyticsDesc}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span><div class="bars"><i style="height:40%"></i><i style="height:65%"></i><i style="height:30%"></i><i style="height:80%"></i><i style="height:55%"></i><i style="height:70%"></i><i style="height:45%"></i><i style="height:90%"></i><i style="height:60%"></i></div></div>
            <div class="ecard"><b>{s.feedback}</b><p>{s.feedbackDesc}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
          </div>
        </div>

        <!-- resource libraries empty -->
        <div class="page" data-page="librariesEmpty">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.rlTitle}</span><span class="desc">{s.rlDesc}</span></span>
            <span class="right"><span class="btn sm" id="btnNewLibrary"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg> {s.newLibrary}</span></span>
          </div>
          <div class="emptybox">{s.empty}</div>
        </div>

        <!-- new resource library -->
        <div class="page" data-page="newLibrary">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.newResourceLibrary}</span><span class="desc">{s.rlDesc}</span></span>
          </div>
          <div class="formcard">
            <p class="lbl">{s.title}</p>
            <div class="inline-form"><div class="field" id="obsLibTitle"><span id="typeLib"></span></div><span class="btn outline" id="btnCreateLibrary">{s.create}</span></div>
          </div>
        </div>

        <!-- libraries list -->
        <div class="page" data-page="librariesList">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.rlTitle}</span><span class="desc">{s.rlDesc}</span></span>
            <span class="right"><span class="btn sm"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg> {s.newLibrary}</span></span>
          </div>
          <div class="cardgrid">
            <div class="rlcard">
              <span class="trash"><svg viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><path d="m19 6-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg></span>
              <b>{s.libName}</b><small>{s.count0}</small>
              <span class="go" id="cardArrow"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
            </div>
          </div>
        </div>

        <!-- library detail empty -->
        <div class="page" data-page="libraryEmpty">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.libName}</span><span class="desc">{s.rlDesc}</span></span>
            <span class="right"><span class="btn sm" id="btnAdd"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg> {s.add}</span></span>
          </div>
          <div class="formcard">
            <p class="lbl">{s.title}</p>
            <div class="inline-form"><div class="field">{s.libName}</div><span class="btn outline">{s.save}</span></div>
            <p class="lbl" style="margin-top:1rem">{s.resources}</p>
            <div class="muted-line">{s.noResources}</div>
          </div>
        </div>

        <!-- new resource form -->
        <div class="page" data-page="newResource">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.newResource}</span></span>
          </div>
          <div class="formcard" id="obsResourceFields">
            <p class="lbl">{s.title}</p>
            <div class="field"><span id="typeRes"></span></div>
            <div class="counter">{s.charsTitle}</div>
            <p class="lbl">{s.description}</p>
            <div class="field area">{s.descVal}</div>
            <div class="counter">{s.charsDesc}</div>
            <p class="lbl">{s.matchingHints} <span class="mut">{s.notShown}</span></p>
            <div class="field area ph">{s.hintsPlaceholder}</div>
            <div class="counter">{s.charsHints}</div>
            <div class="row" style="margin-top:0.7rem">
              <span class="radio on"><span class="dot-radio"></span> {s.url}</span>
              <span class="radio"><span class="dot-radio"></span> {s.uploadedFile}</span>
            </div>
            <div class="row" style="margin-top:0.5rem">
              <span class="dropzone"><svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5-5 5 5"/><path d="M12 5v12"/></svg> {s.dragUpload}</span>
              <span class="filechip"><svg viewBox="0 0 24 24"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg> {s.fileName}</span>
            </div>
            <div class="row" style="justify-content:flex-end; margin-top:1rem; gap:0.5rem">
              <span class="btn ghost">{s.cancel}</span><span class="btn" id="btnCreateResource">{s.create}</span>
            </div>
          </div>
        </div>

        <!-- library with resources table -->
        <div class="page" data-page="libraryTable">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.libName}</span><span class="desc">{s.rlDesc}</span></span>
            <span class="right"><span class="btn sm"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg> {s.add}</span></span>
          </div>
          <div class="formcard">
            <p class="lbl">{s.title}</p>
            <div class="inline-form"><div class="field">{s.libName}</div><span class="btn outline">{s.save}</span></div>
            <p class="lbl" style="margin-top:1rem">{s.resources}</p>
            <table class="res">
              <thead><tr><th>{s.colTitle}</th><th>{s.colDesc}</th><th>{s.colLink}</th><th></th></tr></thead>
