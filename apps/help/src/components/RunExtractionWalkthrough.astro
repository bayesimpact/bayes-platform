---
/**
 * Walkthrough of running an extraction agent on documents (single PDF/image runs and
 * CSV batch runs). Derived from the real components (verified, not copied blind):
 * AgentSessionList.tsx (ExtractionAgentSessionList — New Extraction card + history),
 * ExtractionAgentSessionItem.tsx (PDF/Image & CSV history rows, View/Download JSON),
 * AgentExtractionRoute.tsx (uploader PDF/image/CSV + DocumentList), AgentExtractionRunRoute.tsx
 * (single-doc result: status + duration), CsvExtractor + AgentCsvExtractionRun* (CSV dialog
 * steps + results table). Labels verbatim from extractionAgentSession / agentCsvExtractionRun /
 * status / actions locales (EN + FR). Uses the PRODUCT (coral) palette, pinned locally.
 * Derived 2026-07-16.
 */
type Lang = "en" | "fr"
const { lang = "en" } = Astro.props as { lang?: Lang }

const STRINGS = {
  en: {
    org: "Bayes Impact Demo", studio: "Studio", agents: "Agents",
    agent1: "Document Extractor", conversationAgent: "Conversation Agent", formAgent: "Form Agent",
    settingsName: "Demo", settings: "Settings", evaluations: "Evaluations", analytics: "Analytics", sources: "Sources",
    members: "Members", admin: "Admin",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    typeExtraction: "Extraction",
    newTitle: "New Extraction", newDesc: "Select a document to run extraction.",
    run: "Run", dragOrUpload: "drag or upload a file", open: "Open",
    doc1: "invoice.pdf", doc2: "records.csv",
    resultTitle: "invoice.pdf", statusSuccess: "Success", duration: "Duration: 8s",
    viewJson: "View JSON", downloadJson: "Download JSON",
    resultJson: '{\n  "title": "Invoice 2043",\n  "total": "€1,240.00"\n}',
    csvDialogTitle: "Run CSV Extraction", csvDialogDesc: "Run each record through the agent.",
    stepUpload: "Upload CSV", stepColumns: "Configure Columns", stepScope: "Run Settings",
    colTitle: "Configure column roles", colDesc: "Select the role for each column in your CSV file.",
    colHeader: "Column", roleHeader: "Role",
    roleInput: "Input", roleReference: "Reference", roleIgnore: "Ignore",
    col_a: "customer", col_b: "invoice_text", col_c: "notes",
    back: "Back", next: "Next", csvRun: "Run",
    csvResTitle: "CSV Extraction Results", summary: "Summary",
    total: "Total", processed: "Processed", errors: "Errors",
    downloadDoc: "Download Document", statusHeader: "Status", outputHeader: "Output",
    badgeSuccess: "Success", badgeError: "Error",
    histPdf: "PDF / Image", histCsv: "CSV", histProcessed: "118 of 120 records processed.",
    prev: "Prev", next2: "Next", step: "Step",
    steps: [
      "Open an extraction agent, then click Run on the New Extraction card.",
      "Drop or select a document — a PDF or image runs straight away; a CSV starts a batch.",
      "For a single document, the result page shows the status, duration, and View / Download JSON.",
      "For a CSV, the Run CSV Extraction dialog lets you set each column's role, then Run.",
      "The CSV results show a summary (Total, Processed, Errors) and each record's status; download the results when done.",
      "Every run is kept in the history — reopen it (Open) or delete it later.",
    ],
  },
  fr: {
    org: "Bayes Impact Demo", studio: "Studio", agents: "Agents",
    agent1: "Document Extractor", conversationAgent: "Conversation Agent", formAgent: "Form Agent",
    settingsName: "Demo", settings: "Paramètres", evaluations: "Évaluations", analytics: "Analytique", sources: "Sources",
    members: "Membres", admin: "Admin",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    typeExtraction: "Extraction",
    newTitle: "Nouvelle extraction", newDesc: "Sélectionnez un document pour lancer l'extraction.",
    run: "Exécuter", dragOrUpload: "glissez ou téléchargez un fichier", open: "Ouvrir",
    doc1: "invoice.pdf", doc2: "records.csv",
    resultTitle: "invoice.pdf", statusSuccess: "Succès", duration: "Durée : 8 s",
    viewJson: "Voir JSON", downloadJson: "Télécharger JSON",
    resultJson: '{\n  "title": "Facture 2043",\n  "total": "1 240,00 €"\n}',
    csvDialogTitle: "Lancer l'extraction CSV", csvDialogDesc: "Exécutez chaque enregistrement via l'agent.",
    stepUpload: "Téléverser le CSV", stepColumns: "Configurer les colonnes", stepScope: "Paramètres d'exécution",
    colTitle: "Configurer les rôles des colonnes", colDesc: "Sélectionnez le rôle de chaque colonne de votre fichier CSV.",
    colHeader: "Colonne", roleHeader: "Rôle",
    roleInput: "Entrée", roleReference: "Référence", roleIgnore: "Ignorer",
    col_a: "customer", col_b: "invoice_text", col_c: "notes",
    back: "Retour", next: "Suivant", csvRun: "Lancer",
    csvResTitle: "Résultats de l'extraction CSV", summary: "Résumé",
    total: "Total", processed: "Traités", errors: "Erreurs",
    downloadDoc: "Télécharger le document", statusHeader: "Statut", outputHeader: "Sortie",
    badgeSuccess: "Succès", badgeError: "Erreur",
    histPdf: "PDF / Image", histCsv: "CSV", histProcessed: "118 sur 120 enregistrements traités.",
    prev: "Précédent", next2: "Suivant", step: "Étape",
    steps: [
      "Ouvrez un agent d'extraction, puis cliquez sur Exécuter sur la carte Nouvelle extraction.",
      "Glissez ou sélectionnez un document — un PDF ou une image se lance aussitôt ; un CSV démarre un lot.",
      "Pour un document seul, la page de résultat affiche le statut, la durée, et Voir / Télécharger JSON.",
      "Pour un CSV, la boîte Lancer l'extraction CSV permet de régler le rôle de chaque colonne, puis Exécuter.",
      "Les résultats CSV montrent un résumé (Total, Traités, Erreurs) et le statut de chaque enregistrement ; téléchargez les résultats une fois terminé.",
      "Chaque exécution est conservée dans l'historique — rouvrez-la (Ouvrir) ou supprimez-la plus tard.",
    ],
