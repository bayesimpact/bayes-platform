---
/**
 * Walkthrough of the Reviewer app (reviewing tester sessions in a review campaign).
 * Derived from the real components (verified, not copied blind): WorkspaceItem.tsx
 * (`goToReviewer` + HatGlassesIcon), ReviewerRoute.tsx (HorizontalNavbar appName =
 * reviewerCampaigns:shell.title), ReviewerCampaignsList.tsx, CampaignSessionList.tsx,
 * ReviewerSessionsTable.tsx, ReviewerAgentSession/ReviewerSessionReview.tsx
 * (blind → revealed), FactualAnswersPanel/TesterFeedbackPanel/OtherReviewersPanel,
 * BlindBanner.tsx, ReviewerReviewForm.tsx, and the shared studio CampaignReport.
 * Labels verbatim from reviewer-campaigns / reviewCampaigns:report locales (EN + FR).
 * Uses the PRODUCT (coral) palette, pinned locally. Derived 2026-07-16.
 */
type Lang = "en" | "fr"
const { lang = "en" } = Astro.props as { lang?: Lang }

const STRINGS = {
  en: {
    appName: "Reviewer", workspaces: "Workspaces", org: "Bayes Impact Demo", projectName: "Demo",
    appStudio: "Studio", appApp: "App", appEval: "Evaluation", appReview: "Review",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    myTitle: "My review campaigns", mySubtitle: "Active campaigns where you're a reviewer.",
    cardDesc: "Review tester sessions and submit your own rating.",
    campaignName: "Agent pilot", campaignDesc: "Help us evaluate the assistant before launch.",
    agentName: "Helpful Assistant", agentType: "Conversation agent",
    campaignReport: "Campaign report",
    sessionsHeading: "Sessions to review", sessionsCount: "3 total", pending: " · 1 pending",
    hSession: "Session", hStarted: "Started", hMessages: "Messages", hReviewers: "Reviewers", hMyReview: "My review",
    yourSession: "your session", submitted: "Submitted", pendingBadge: "Pending",
    view: "View", review: "Review",
    tester: "Tester f47ac10b",
    userMsg: "How do I reset my password?",
    botMsg: "Go to Settings → Security and click “Reset password”. You'll get an email with a link.",
    transcriptTitle: "Transcript",
    factsTitle: "Session facts", factsDesc: "Objective answers the tester provided about this session.",
    factQ: "Did the agent answer the question?", factA: "Yes",
    blindMsg: "The tester's rating and comment are hidden until you submit your own review — so your judgment stays independent.",
    yourReview: "Your review", ratingLabel: "Your rating", commentLabel: "Comment",
    commentPh: "What worked, what didn't?", reviewQ: "Was the answer helpful?",
    submitReview: "Submit review", saveChanges: "Save changes",
    testerFeedback: "Tester feedback", overallRating: "Overall rating", tfComment: "Clear and quick.",
    otherReviewers: "Other reviewers (1)", reviewerLabel: "Reviewer 9c8b7a6d",
    reportTitle: "Campaign report", downloadCsv: "Download CSV",
    mSessions: "Sessions", mTester: "Mean tester rating", mReviewer: "Mean reviewer rating", mEnd: "Mean end-of-phase",
    matrixTitle: "Session matrix", mxSession: "Session", mxStarted: "Started", mxTester: "Tester", mxReviewers: "Reviewers", mxMean: "Mean reviewer", mxSpread: "Spread",
    prev: "Prev", next: "Next", step: "Step",
    steps: [
      "From the home page, open your workspace's menu and choose Review — the reviewer app.",
      "My review campaigns lists the campaigns you review. Open one.",
      "Sessions to review lists testers' sessions. Click Review on one (you can't review your own).",
      "Read the transcript and answer Your review. The tester's rating is hidden — that's the blind review. Then Submit review.",
      "After submitting, the tester's feedback and other reviewers become visible; you can Save changes.",
      "Open the Campaign report to see aggregated results.",
      "The report shows mean ratings and a per-session matrix, with Download CSV.",
    ],
  },
  fr: {
    appName: "Relecteur", workspaces: "Espaces de travail", org: "Bayes Impact Demo", projectName: "Demo",
    appStudio: "Studio", appApp: "Application", appEval: "Évaluation", appReview: "Révision",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    myTitle: "Mes campagnes d'évaluation", mySubtitle: "Campagnes actives où vous êtes relecteur.",
    cardDesc: "Relisez les sessions des testeurs et soumettez votre propre évaluation.",
    campaignName: "Pilote agent", campaignDesc: "Aidez-nous à évaluer l'assistant avant son lancement.",
    agentName: "Helpful Assistant", agentType: "Agent conversationnel",
    campaignReport: "Rapport de la campagne",
    sessionsHeading: "Sessions à relire", sessionsCount: "3 au total", pending: " · 1 en attente",
    hSession: "Session", hStarted: "Démarrée", hMessages: "Messages", hReviewers: "Relecteurs", hMyReview: "Ma relecture",
    yourSession: "votre session", submitted: "Soumise", pendingBadge: "En attente",
    view: "Voir", review: "Relire",
    tester: "Testeur f47ac10b",
    userMsg: "Comment réinitialiser mon mot de passe ?",
    botMsg: "Allez dans Paramètres → Sécurité et cliquez sur « Réinitialiser le mot de passe ». Vous recevrez un email avec un lien.",
    transcriptTitle: "Transcription",
    factsTitle: "Faits de la session", factsDesc: "Réponses objectives fournies par le testeur sur cette session.",
    factQ: "L'agent a-t-il répondu à la question ?", factA: "Oui",
    blindMsg: "La note et le commentaire du testeur sont masqués jusqu'à ce que vous soumettiez votre propre relecture — afin que votre jugement reste indépendant.",
    yourReview: "Votre relecture", ratingLabel: "Votre note", commentLabel: "Commentaire",
    commentPh: "Qu'est-ce qui a fonctionné, qu'est-ce qui n'a pas fonctionné ?", reviewQ: "La réponse était-elle utile ?",
    submitReview: "Soumettre la relecture", saveChanges: "Enregistrer les modifications",
    testerFeedback: "Retour du testeur", overallRating: "Note globale", tfComment: "Clair et rapide.",
    otherReviewers: "Autres relecteurs (1)", reviewerLabel: "Relecteur 9c8b7a6d",
    reportTitle: "Rapport de campagne", downloadCsv: "Télécharger le CSV",
    mSessions: "Sessions", mTester: "Note moyenne des testeurs", mReviewer: "Note moyenne des relecteurs", mEnd: "Moyenne fin de phase",
    matrixTitle: "Matrice des sessions", mxSession: "Session", mxStarted: "Démarrée", mxTester: "Testeur", mxReviewers: "Relecteurs", mxMean: "Moyenne relecteurs", mxSpread: "Écart",
    prev: "Précédent", next: "Suivant", step: "Étape",
    steps: [
      "Sur la page d'accueil, ouvrez le menu de votre espace de travail et choisissez Révision — l'application relecteur.",
      "Mes campagnes d'évaluation liste les campagnes que vous relisez. Ouvrez-en une.",
      "Sessions à relire liste les sessions des testeurs. Cliquez sur Relire (vous ne pouvez pas relire la vôtre).",
      "Lisez la transcription et répondez à Votre relecture. La note du testeur est masquée — c'est la relecture à l'aveugle. Puis Soumettez la relecture.",
      "Après l'envoi, le retour du testeur et les autres relecteurs deviennent visibles ; vous pouvez Enregistrer les modifications.",
      "Ouvrez le Rapport de la campagne pour voir les résultats agrégés.",
      "Le rapport montre les notes moyennes et une matrice par session, avec Télécharger le CSV.",
    ],
  },
} as const

const s = STRINGS[lang]

const steps = [
  { page: "home", spot: "btnReview", observe: [] },
  { page: "campaigns", spot: "cardOpen", observe: [] },
  { page: "landing", spot: "btnRowReview", observe: ["obsTable"] },
  { page: "sessionBlind", spot: "btnSubmit", observe: ["obsBlind"] },
  { page: "sessionRevealed", spot: "", observe: ["obsRevealed"] },
  { page: "landing", spot: "btnReport", observe: [] },
  { page: "report", spot: "", observe: ["obsReport"] },
].map((step, i) => ({ ...step, text: s.steps[i] }))

const labels = { prev: s.prev, next: s.next, step: s.step, navApp: s.appName, navHome: s.workspaces }
---

<div class="rvw" role="group" aria-label={s.appName}>
  <div class="frame">
    <div class="nav">
      <span class="logo"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 410.85 405.35" aria-hidden="true"><path d="M366.77,161.43H247V41.61a41.37,41.37,0,1,0-82.74,0V161.43H44.39a41.37,41.37,0,0,0,0,82.74H164.21V364A41.37,41.37,0,1,0,247,364V244.17H366.77a41.37,41.37,0,1,0,0-82.74Z"/><circle cx="205.58" cy="364.27" r="41.05"/><circle cx="369.79" cy="202.64" r="41.05"/><circle cx="41.05" cy="202.64" r="41.05"/><circle cx="205.58" cy="41.05" r="41.05"/><circle cx="205.58" cy="202.64" r="41.05"/></svg></span>
      <span class="appname" id="navTitle">{s.appName}</span>
      <span class="navuser"><span class="avatar">AM</span><svg viewBox="0 0 24 24"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg></span>
    </div>

    <div class="panel">
      <div class="canvas">
        <!-- Home: workspace app menu (step 1) -->
        <div class="page" data-page="home" data-active="true">
          <div class="page-head"><span><span class="ttl">{s.workspaces}</span></span></div>
          <div class="wscard">
            <span class="ws-name">{s.projectName}</span>
            <div class="openbtn">
              <span class="split-main"><svg viewBox="0 0 24 24"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg> {s.appStudio}</span>
              <span class="split-chev"><svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"/></svg></span>
            </div>
            <div class="menu">
              <span class="menu-item"><svg viewBox="0 0 24 24"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg> {s.appApp}</span>
              <span class="menu-item"><svg viewBox="0 0 24 24"><path d="M14 2v6a2 2 0 0 0 .245.96l5.51 10.08A2 2 0 0 1 18 22H6a2 2 0 0 1-1.755-2.96l5.51-10.08A2 2 0 0 0 10 8V2"/><path d="M6.453 15h11.094"/><path d="M8.5 2h7"/></svg> {s.appEval}</span>
              <span class="menu-item" id="btnReview"><svg viewBox="0 0 24 24"><path d="M14 18a2 2 0 0 0-4 0"/><path d="m19 11-2.11-6.657a2 2 0 0 0-2.752-1.148l-1.276.61A2 2 0 0 1 12 4H8.5a2 2 0 0 0-1.925 1.456L5 11"/><path d="M2 11h20"/><circle cx="17" cy="18" r="3"/><circle cx="7" cy="18" r="3"/></svg> {s.appReview}</span>
            </div>
          </div>
        </div>

        <!-- My review campaigns (step 2) -->
        <div class="page" data-page="campaigns">
          <div class="page-head"><span><span class="ttl">{s.myTitle}</span><span class="desc">{s.mySubtitle}</span></span></div>
          <div class="cards2">
            <div class="ccard">
              <b>{s.campaignName}</b>
              <p>{s.campaignDesc}</p>
              <p class="muted-txt">{s.cardDesc}</p>
              <span class="arrowbtn" id="cardOpen"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
            </div>
          </div>
        </div>

        <!-- Campaign landing / sessions table (steps 3, 6) -->
        <div class="page" data-page="landing">
          <div class="page-head">
            <span class="backbtn"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.campaignName}</span><span class="desc">{s.campaignDesc}</span></span>
            <span class="right"><span class="btn outline" id="btnReport"><svg viewBox="0 0 24 24"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg> {s.campaignReport}</span></span>
          </div>
          <div class="body">
            <div class="agentline"><b>{s.agentName}</b><span class="badge">{s.agentType}</span></div>
            <section class="sec">
              <header class="sec-head"><h3>{s.sessionsHeading}</h3><span class="muted-txt">{s.sessionsCount}<span class="pend">{s.pending}</span></span></header>
              <div class="rtable" id="obsTable">
                <div class="rt-head"><span>{s.hSession}</span><span>{s.hStarted}</span><span class="num">{s.hMessages}</span><span class="num">{s.hReviewers}</span><span>{s.hMyReview}</span><span></span></div>
                <div class="rt-row">
                  <span class="mono">f47ac10b</span><span class="muted-txt">2d ago</span><span class="num">8</span><span class="num">2</span>
                  <span><span class="st-pending">{s.pendingBadge}</span></span>
                  <span class="ta-right"><span class="btn sm" id="btnRowReview">{s.review}</span></span>
                </div>
                <div class="rt-row">
                  <span class="mono">9c8b7a6d</span><span class="muted-txt">3d ago</span><span class="num">5</span><span class="num">1</span>
                  <span><span class="st-ok"><svg viewBox="0 0 24 24"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg> {s.submitted}</span></span>
                  <span class="ta-right"><span class="btn ghost sm">{s.view}</span></span>
                </div>
                <div class="rt-row">
                  <span class="mono">3e2d1c0b <span class="badge tiny">{s.yourSession}</span></span><span class="muted-txt">3d ago</span><span class="num">6</span><span class="num">0</span>
                  <span><span class="st-pending">{s.pendingBadge}</span></span>
                  <span class="ta-right"><span class="btn ghost sm disabled">{s.review}</span></span>
                </div>
              </div>
            </section>
          </div>
        </div>

        <!-- Session review — blind (step 4) -->
        <div class="page" data-page="sessionBlind">
          <div class="page-head">
            <span class="backbtn"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.agentName}</span><span class="desc"><svg viewBox="0 0 24 24"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> {s.tester}</span></span>
            <span class="right"><span class="badge">{s.agentType}</span></span>
          </div>
          <div class="review-grid">
            <div class="col-left">
              <div class="panelbox" id="obsBlind">
                <b>{s.factsTitle}</b>
                <p class="muted-txt">{s.factsDesc}</p>
                <div class="kv"><span>{s.factQ}</span><b>{s.factA}</b></div>
              </div>
              <div class="panelbox">
                <b>{s.transcriptTitle}</b>
                <div class="msg user"><span>{s.userMsg}</span></div>
                <div class="msg bot"><span>{s.botMsg}</span></div>
              </div>
            </div>
            <div class="col-right">
              <div class="banner"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg><span>{s.blindMsg}</span></div>
              <b class="section-h">{s.yourReview}</b>
              <div class="fld"><p class="lbl">{s.ratingLabel} <span class="req">*</span></p><span class="stars"><i class="star on"></i><i class="star on"></i><i class="star on"></i><i class="star"></i><i class="star"></i></span></div>
              <div class="fld"><p class="lbl">{s.commentLabel}</p><span class="textarea muted-txt">{s.commentPh}</span></div>
              <div class="fld"><p class="lbl">{s.reviewQ}</p><span class="stars"><i class="star on"></i><i class="star on"></i><i class="star on"></i><i class="star on"></i><i class="star"></i></span></div>
              <div class="foot-right"><span class="btn" id="btnSubmit">{s.submitReview}</span></div>
            </div>
          </div>
        </div>

        <!-- Session review — revealed after submit (step 5) -->
        <div class="page" data-page="sessionRevealed">
          <div class="page-head">
            <span class="backbtn"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.agentName}</span><span class="desc"><svg viewBox="0 0 24 24"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> {s.tester}</span></span>
            <span class="right"><span class="badge">{s.agentType}</span></span>
          </div>
          <div class="review-grid">
            <div class="col-left" id="obsRevealed">
              <div class="panelbox">
                <b>{s.testerFeedback}</b>
                <div class="kv"><span>{s.overallRating}</span><span class="stars sm"><i class="star on"></i><i class="star on"></i><i class="star on"></i><i class="star on"></i><i class="star"></i> <span class="rn">4/5</span></span></div>
                <p class="quote">“{s.tfComment}”</p>
              </div>
              <div class="panelbox">
                <b>{s.otherReviewers}</b>
                <div class="kv"><span>{s.reviewerLabel}</span><span class="stars sm"><i class="star on"></i><i class="star on"></i><i class="star on"></i><i class="star on"></i><i class="star on"></i> <span class="rn">5/5</span></span></div>
              </div>
            </div>
            <div class="col-right">
              <b class="section-h">{s.yourReview}</b>
              <div class="fld"><p class="lbl">{s.ratingLabel} <span class="req">*</span></p><span class="stars"><i class="star on"></i><i class="star on"></i><i class="star on"></i><i class="star"></i><i class="star"></i></span></div>
              <div class="fld"><p class="lbl">{s.commentLabel}</p><span class="textarea">Solid answer, minor gaps.</span></div>
              <div class="foot-right"><span class="btn">{s.saveChanges}</span></div>
            </div>
          </div>
        </div>

        <!-- Campaign report (step 7) -->
        <div class="page" data-page="report">
          <div class="page-head">
            <span class="backbtn"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.reportTitle}</span></span>
            <span class="right"><span class="btn outline"><svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg> {s.downloadCsv}</span></span>
          </div>
          <div class="body" id="obsReport">
            <div class="statcards">
              <div class="stat"><span class="sl">{s.mSessions}</span><span class="sv">12</span></div>
              <div class="stat"><span class="sl">{s.mTester}</span><span class="sv">4.2</span></div>
              <div class="stat"><span class="sl">{s.mReviewer}</span><span class="sv">3.9</span></div>
              <div class="stat"><span class="sl">{s.mEnd}</span><span class="sv">4.0</span></div>
            </div>
            <section class="sec">
              <h3>{s.matrixTitle}</h3>
              <div class="rtable">
                <div class="rt-head mx"><span>{s.mxSession}</span><span>{s.mxStarted}</span><span>{s.mxTester}</span><span class="num">{s.mxReviewers}</span><span class="num">{s.mxMean}</span><span class="num">{s.mxSpread}</span></div>
                <div class="rt-row mx"><span class="mono">f47ac10b</span><span class="muted-txt">2d ago</span><span class="mono">f47a…</span><span class="num">2</span><span class="num">3.5</span><span class="num">1.0</span></div>
                <div class="rt-row mx"><span class="mono">9c8b7a6d</span><span class="muted-txt">3d ago</span><span class="mono">9c8b…</span><span class="num">1</span><span class="num">5.0</span><span class="num">0.0</span></div>
              </div>
            </section>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Controls -->
  <div class="controls">
    <button class="navbtn" data-prev><svg viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg> {s.prev}</button>
    <button class="ctrl" data-playpause aria-label="Play / pause">⏸</button>
    <span class="cap"><span class="st" data-stepcount></span><span class="tx" data-captext></span></span>
    <span class="dots-nav" data-dots role="tablist" aria-label="Steps"></span>
    <button class="navbtn primary" data-next>{s.next} <svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></button>
  </div>
  <div class="progress"><i data-bar></i></div>
</div>

<script define:vars={{ steps, labels }}>
  const cs = document.currentScript
  const rvw =
    cs && cs.previousElementSibling && cs.previousElementSibling.classList.contains("rvw")
      ? cs.previousElementSibling
      : document.querySelector(".rvw")
  const q = (sel) => rvw.querySelector(sel)
  const pages = [...rvw.querySelectorAll(".page")]
  const dotsWrap = rvw.querySelector("[data-dots]")
  const bar = rvw.querySelector("[data-bar]")
  const capText = rvw.querySelector("[data-captext]")
  const stepCount = rvw.querySelector("[data-stepcount]")
  const playPause = rvw.querySelector("[data-playpause]")
  const prevBtn = rvw.querySelector("[data-prev]")
  const nextBtn = rvw.querySelector("[data-next]")
  const DUR = 6000
  let idx = 0, playing = true, timer = null

  steps.forEach((_, i) => {
    const b = document.createElement("button")
    b.className = "dotnav"; b.setAttribute("role", "tab"); b.setAttribute("aria-label", labels.step + " " + (i + 1))
    b.addEventListener("click", () => go(i)); dotsWrap.appendChild(b)
  })
  const dots = [...dotsWrap.children]

  function clearMarks() {
    rvw.querySelectorAll(".spot-on").forEach((el) => el.classList.remove("spot-on"))
    rvw.querySelectorAll(".observe-on").forEach((el) => el.classList.remove("observe-on"))
  }
  function render() {
    const step = steps[idx]
    pages.forEach((p) => p.setAttribute("data-active", String(p.dataset.page === step.page)))
    dots.forEach((d, i) => d.classList.toggle("on", i === idx))
    stepCount.textContent = labels.step + " " + (idx + 1) + " / " + steps.length
    capText.textContent = step.text
    const navTitle = q("#navTitle")
    if (navTitle) navTitle.textContent = step.page === "home" ? labels.navHome : labels.navApp

    clearMarks()
    const active = idx
    setTimeout(() => {
      if (active !== idx) return
      if (step.spot) q("#" + step.spot)?.classList.add("spot-on")
      step.observe.forEach((id) => q("#" + id)?.classList.add("observe-on"))
    }, 260)

    bar.classList.remove("run"); void bar.offsetWidth
    bar.style.setProperty("--dur", DUR + "ms")
    if (playing) bar.classList.add("run")
  }
  function schedule() { clearTimeout(timer); if (playing) timer = setTimeout(() => go(idx + 1), DUR) }
  function go(n) { idx = (n + steps.length) % steps.length; render(); schedule() }
  function setPlaying(p) {
    playing = p; playPause.textContent = p ? "⏸" : "▶"
    if (p) { bar.classList.add("run"); schedule() } else { clearTimeout(timer); bar.classList.remove("run") }
  }
  prevBtn.addEventListener("click", () => go(idx - 1))
  nextBtn.addEventListener("click", () => go(idx + 1))
  playPause.addEventListener("click", () => setPlaying(!playing))

  render(); schedule()
</script>

