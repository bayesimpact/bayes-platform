---
/**
 * Animated, full-page walkthrough of the Documents flow, mirroring the real
 * Studio interface (same shell, exact Lucide icons, real brand logo). Shares the
 * exact FORM of the other help-center walkthroughs — only the content differs.
 * Pass `lang="fr"` for the French copy.
 */
type Lang = "en" | "fr"
const { lang = "en" } = Astro.props as { lang?: Lang }

const STRINGS = {
  en: {
    org: "Bayes Impact Demo", studio: "Studio", agents: "Agents",
    agent1: "Bayes Assistant", conversationAgent: "Conversation Agent", extractionAgent: "Extraction Agent", formAgent: "Form Agent",
    settingsName: "Demo", settings: "Settings", evaluations: "Evaluations", analytics: "Analytics", sources: "Sources",
    documents: "Documents", webSources: "Web sources", resourceLibraries: "Resource libraries", members: "Members", admin: "Admin",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    workspace: "Workspace", conversation: "Conversation", extraction: "Extraction", form: "Form",
    timeAgo: "About 1 hour ago", create: "Create",
    newAgent: "New Agent", newAgentDesc: "An agent can perform specific tasks based on its type and configuration.",
    documentsDesc: "Enhance your agents' knowledge and capabilities by adding documents.",
    membersDesc: "Invite admins to join your workspace to collaborate together.",
    reviewCampaigns: "Review campaigns", reviewDesc: "Invite testers and reviewers to evaluate an agent.",
    analyticsDesc: "View analytics for your project, including conversations, average questions per session, and more.",
    evalDesc: "Test the performance of your agents.",
    dragUpload: "Drag or upload a file", tagsBtn: "Tags",
    emptyTitle: "No documents yet", emptyDesc: "Upload your first document to get started.",
    uploadTitle: "Tags for this upload", uploadDesc: "Optional: choose tags to apply to every file in this upload.",
    fileCount: "You're about to upload one file.", tags: "Tags", addTag: "Add tag", cancel: "Cancel", uploadConfirm: "Upload",
    colTitle: "Title", colTags: "Tags", colStatus: "Embedding Status", colUpdated: "Updated At",
    docName: "handbook.pdf", doc2: "faq.pdf", doc3: "policy.pdf", tagName: "private-documents",
    statusProcessing: "Processing", statusReady: "Ready", updatedAgo: "less than a minute ago",
    download: "Download Document", view: "View", edit: "Edit", del: "Delete",
    selected2: "2 selected", selected3: "3 selected", removeTag: "Remove tag",
    prev: "Prev", next: "Next", step: "Step",
    steps: [
      "Open the Sources section in the left menu.",
      "Select Documents.",
      "Click Drag or upload a file to bring your document to the platform.",
      "Optionally click Add tag, then click Upload.",
      "Wait for the Embedding Status to become “Ready”.",
      "Download, View, Edit or Delete a document from the ⋮ menu.",
      "Select documents to manage them together: Add tag, Remove tag or Delete.",
      "Tick the box next to Title to select all documents.",
    ],
  },
  fr: {
    org: "Bayes Impact Demo", studio: "Studio", agents: "Agents",
    agent1: "Bayes Assistant", conversationAgent: "Conversation Agent", extractionAgent: "Extraction Agent", formAgent: "Form Agent",
    settingsName: "Demo", settings: "Paramètres", evaluations: "Évaluations", analytics: "Analytique", sources: "Sources",
    documents: "Documents", webSources: "Sites web", resourceLibraries: "Bibliothèques de ressources", members: "Membres", admin: "Admin",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    workspace: "Espace de travail", conversation: "Conversation", extraction: "Extraction", form: "Formulaire",
    timeAgo: "Il y a environ 1 heure", create: "Créer",
    newAgent: "Nouvel agent", newAgentDesc: "Un agent peut effectuer des tâches spécifiques selon son type et sa configuration.",
    documentsDesc: "Enrichissez les connaissances et capacités de vos agents en ajoutant des documents.",
    membersDesc: "Invitez des administrateurs à rejoindre votre espace de travail pour collaborer ensemble.",
    reviewCampaigns: "Campagnes de revue", reviewDesc: "Invitez des testeurs et des relecteurs à évaluer un agent.",
    analyticsDesc: "Consultez les analyses de votre espace de travail : conversations, questions moyennes par session, et plus.",
    evalDesc: "Testez les performances de vos agents.",
    dragUpload: "Glissez ou téléversez un fichier", tagsBtn: "Étiquettes",
    emptyTitle: "Aucun document pour le moment", emptyDesc: "Téléversez votre premier document pour commencer.",
    uploadTitle: "Tags pour cet envoi", uploadDesc: "Facultatif : choisissez des tags à appliquer à chaque fichier de cet envoi.",
    fileCount: "Vous êtes sur le point de téléverser un fichier.", tags: "Tags", addTag: "Ajouter une étiquette", cancel: "Annuler", uploadConfirm: "Téléverser",
    colTitle: "Titre", colTags: "Tags", colStatus: "Statut des embeddings", colUpdated: "Mis à jour le",
    docName: "guide.pdf", doc2: "faq.pdf", doc3: "politique.pdf", tagName: "private-documents",
    statusProcessing: "En cours", statusReady: "Prêt", updatedAgo: "il y a moins d'une minute",
    download: "Télécharger le document", view: "Voir", edit: "Modifier", del: "Supprimer",
    selected2: "2 sélectionnés", selected3: "3 sélectionnés", removeTag: "Retirer un tag",
    prev: "Précédent", next: "Suivant", step: "Étape",
    steps: [
      "Ouvrez la section Sources dans le menu de gauche.",
      "Sélectionnez Documents.",
      "Cliquez sur Glissez ou téléversez un fichier pour importer votre document.",
      "Cliquez éventuellement sur Ajouter une étiquette, puis sur Téléverser.",
      "Attendez que le statut des embeddings passe à « Prêt ».",
      "Télécharger, Voir, Modifier ou Supprimer un document depuis le menu ⋮.",
      "Sélectionnez des documents pour les gérer ensemble : Ajouter une étiquette, Retirer un tag ou Supprimer.",
      "Cochez la case à côté de Titre pour tout sélectionner.",
    ],
  },
} as const

const s = STRINGS[lang]

const steps = [
  { page: "overview", sources: false, nav: "", spot: "navSources", observe: [] },
  { page: "overview", sources: true, nav: "", spot: "navDocuments", observe: [] },
  { page: "docsEmpty", sources: true, nav: "documents", spot: "btnUpload", observe: [] },
  { page: "uploadDialog", sources: true, nav: "documents", spot: "btnUploadConfirm", observe: ["obsAddTag"] },
  { page: "docsTable", sources: true, nav: "documents", spot: "", observe: ["obsStatus"] },
  { page: "docsDots", sources: true, nav: "documents", spot: "rowDots", observe: ["obsMenu"] },
  { page: "docsBulk", sources: true, nav: "documents", spot: "", observe: ["obsToolbar"] },
  { page: "docsSelectAll", sources: true, nav: "documents", spot: "headCheck", observe: ["obsToolbar2"] },
].map((step, i) => ({ ...step, text: s.steps[i] }))

const labels = { prev: s.prev, next: s.next, step: s.step }
---

<div class="dsw" role="group" aria-label={s.documents}>
  <div class="shell">
    <!-- Sidebar -->
    <aside class="sb">
      <div class="sb-head">
        <span class="logo"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 410.85 405.35" aria-hidden="true"><path d="M366.77,161.43H247V41.61a41.37,41.37,0,1,0-82.74,0V161.43H44.39a41.37,41.37,0,0,0,0,82.74H164.21V364A41.37,41.37,0,1,0,247,364V244.17H366.77a41.37,41.37,0,1,0,0-82.74Z"/><circle cx="205.58" cy="364.27" r="41.05"/><circle cx="369.79" cy="202.64" r="41.05"/><circle cx="41.05" cy="202.64" r="41.05"/><circle cx="205.58" cy="41.05" r="41.05"/><circle cx="205.58" cy="202.64" r="41.05"/></svg></span>
        <span class="org"><b>{s.org}</b><small>{s.studio}</small></span>
      </div>
      <div class="sb-scroll">
        <div class="grp-label">{s.agents}<span class="add"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg></span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg><span>{s.agent1}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg><span>{s.conversationAgent}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 8h8"/><path d="M7 12h10"/><path d="M7 16h6"/></svg><span>{s.extractionAgent}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M4 14h6"/><path d="M4 2h10"/><rect x="4" y="18" width="16" height="4" rx="1"/><rect x="4" y="6" width="16" height="4" rx="1"/></svg><span>{s.formAgent}</span></div>

        <div class="grp-label stack"><span class="name">{s.settingsName}</span><span>{s.settings}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/></svg><span>{s.evaluations}</span><svg class="chev" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg><span>{s.analytics}</span></div>
        <div class="navitem" id="navSources"><svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 15 21.84"/><path d="M21 5V8"/><path d="M21 12L18 17H22L19 22"/><path d="M3 12A9 3 0 0 0 14.59 14.87"/></svg><span>{s.sources}</span><svg class="chev" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></div>
        <div class="subwrap" id="sourcesSub">
          <div class="subitem" id="navDocuments"><svg viewBox="0 0 24 24"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg><span>{s.documents}</span></div>
          <div class="subitem"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg><span>{s.webSources}</span></div>
          <div class="subitem"><svg viewBox="0 0 24 24"><rect width="8" height="18" x="3" y="3" rx="1"/><path d="M7 3v18"/><path d="M20.4 18.9c.2.5-.1 1.1-.6 1.3l-1.9.7c-.5.2-1.1-.1-1.3-.6L11.1 5.1c-.2-.5.1-1.1.6-1.3l1.9-.7c.5-.2 1.1.1 1.3.6Z"/></svg><span>{s.resourceLibraries}</span></div>
        </div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg><span>{s.members}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg><span>{s.admin}</span></div>
      </div>
      <div class="sb-user">
        <span class="avatar">AM</span>
        <span class="who"><b>{s.userName}</b><small>{s.userEmail}</small></span>
        <span class="updown"><svg viewBox="0 0 24 24"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg></span>
      </div>
    </aside>

    <!-- Main inset -->
    <div class="inset">
      <div class="topbar">
        <span class="trig"><svg viewBox="0 0 24 24"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg></span>
      </div>
      <div class="canvas">
        <span class="fab"><svg viewBox="0 0 24 24"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg></span>

        <!-- workspace overview (steps 1 & 2) -->
        <div class="page" data-page="overview" data-active="true">
          <div class="page-head plain">
            <span><span class="ttl">{s.settingsName}</span><span class="desc">{s.workspace}</span></span>
          </div>
          <div class="cards3">
            <div class="ecard"><span class="cat">{s.conversation}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg> {s.agent1}</b><p>{s.timeAgo}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><span class="cat">{s.conversation}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg> {s.conversationAgent}</b><p>{s.timeAgo}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><span class="cat">{s.extraction}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 8h8"/><path d="M7 12h10"/><path d="M7 16h6"/></svg> {s.extractionAgent}</b><p>{s.timeAgo}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><span class="cat">{s.form}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M4 14h6"/><path d="M4 2h10"/><rect x="4" y="18" width="16" height="4" rx="1"/><rect x="4" y="6" width="16" height="4" rx="1"/></svg> {s.formAgent}</b><p>{s.timeAgo}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><b>{s.newAgent}</b><p>{s.newAgentDesc}</p><span class="btn sm">{s.create} <svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg></span></div>
            <div class="ecard"><b>{s.documents}</b><p>{s.documentsDesc}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><b>{s.members}</b><p>{s.membersDesc}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><b>{s.reviewCampaigns}</b><p>{s.reviewDesc}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><b>{s.analytics}</b><p>{s.analyticsDesc}</p><div class="bars"><i style="height:40%"></i><i style="height:65%"></i><i style="height:30%"></i><i style="height:80%"></i><i style="height:55%"></i><i style="height:70%"></i><i style="height:45%"></i><i style="height:90%"></i></div></div>
          </div>
        </div>

        <!-- documents empty (step 3) -->
        <div class="page" data-page="docsEmpty">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.documents}</span><span class="desc">{s.documentsDesc}</span></span>
            <span class="right">
              <span class="btn sm" id="btnUpload"><svg viewBox="0 0 24 24"><path d="M12 13v8"/><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="m8 17 4-4 4 4"/></svg> {s.dragUpload}</span>
              <span class="btn outline sm"><svg viewBox="0 0 24 24"><path d="M13.172 2a2 2 0 0 1 1.414.586l6.71 6.71a2.4 2.4 0 0 1 0 3.408l-4.592 4.592a2.4 2.4 0 0 1-3.408 0l-6.71-6.71A2 2 0 0 1 6 9.172V3a1 1 0 0 1 1-1z"/><path d="M2 7v6.172a2 2 0 0 0 .586 1.414l6.71 6.71a2.4 2.4 0 0 0 3.191.193"/><circle cx="10.5" cy="6.5" r=".5" fill="currentColor"/></svg> {s.tagsBtn}</span>
            </span>
          </div>
          <div class="emptybox">
            <svg class="empty-ico" viewBox="0 0 24 24"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
            <b>{s.emptyTitle}</b>
            <p>{s.emptyDesc}</p>
            <span class="btn sm"><svg viewBox="0 0 24 24"><path d="M12 13v8"/><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="m8 17 4-4 4 4"/></svg> {s.dragUpload}</span>
          </div>
        </div>

        <!-- upload dialog (step 4) -->
        <div class="page" data-page="uploadDialog">
          <div class="scrim"></div>
          <div class="modal">
            <div class="mhead"><b>{s.uploadTitle}</b><p>{s.uploadDesc}</p></div>
            <p class="muted-line">{s.fileCount}</p>
            <p class="lbl">{s.tags}</p>
            <div class="row"><span class="btn outline sm" id="obsAddTag"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg> {s.addTag}</span></div>
            <div class="row" style="justify-content:flex-end; margin-top:1rem; gap:0.5rem"><span class="btn ghost">{s.cancel}</span><span class="btn" id="btnUploadConfirm">{s.uploadConfirm}</span></div>
          </div>
        </div>

        <!-- documents table, processing (step 5) -->
        <div class="page" data-page="docsTable">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.documents}</span><span class="desc">{s.documentsDesc}</span></span>
            <span class="right"><span class="btn sm"><svg viewBox="0 0 24 24"><path d="M12 13v8"/><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="m8 17 4-4 4 4"/></svg> {s.dragUpload}</span></span>
          </div>
          <table class="res">
            <thead><tr><th class="cbcol"><span class="cb"></span></th><th>{s.colTitle}</th><th>{s.colTags}</th><th>{s.colStatus}</th><th>{s.colUpdated}</th><th></th></tr></thead>
            <tbody><tr>
              <td class="cbcol"><span class="cb"></span></td>
              <td>{s.docName}</td><td></td>
              <td id="obsStatus"><span class="badge crawling"><svg class="spin" viewBox="0 0 24 24"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/></svg> {s.statusProcessing}</span></td>
              <td class="muted-cell">{s.updatedAgo}</td>
              <td class="dots"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg></td>
            </tr></tbody>
          </table>
        </div>

        <!-- documents table + dots menu (step 6) -->
        <div class="page" data-page="docsDots">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.documents}</span><span class="desc">{s.documentsDesc}</span></span>
          </div>
          <table class="res">
            <thead><tr><th class="cbcol"><span class="cb"></span></th><th>{s.colTitle}</th><th>{s.colTags}</th><th>{s.colStatus}</th><th>{s.colUpdated}</th><th></th></tr></thead>
            <tbody><tr>
              <td class="cbcol"><span class="cb"></span></td>
              <td>{s.docName}</td>
              <td><span class="chip">{s.tagName}</span></td>
              <td><span class="badge ready">{s.statusReady}</span></td>
              <td class="muted-cell">{s.updatedAgo}</td>
              <td class="dots"><span id="rowDots"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg></span></td>
            </tr></tbody>
          </table>
          <div class="menu" id="obsMenu">
            <div class="menu-item"><svg viewBox="0 0 24 24"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M12 18v-6"/><path d="m9 15 3 3 3-3"/></svg> {s.download}</div>
            <div class="menu-item"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg> {s.view}</div>
            <div class="menu-item"><svg viewBox="0 0 24 24"><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/><path d="m15 5 4 4"/></svg> {s.edit}</div>
            <div class="menu-sep"></div>
            <div class="menu-item danger"><svg viewBox="0 0 24 24"><path d="M10 11v6"/><path d="M14 11v6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> {s.del}</div>
          </div>
        </div>

        <!-- documents bulk select (step 7) -->
        <div class="page" data-page="docsBulk">
          <div class="page-head">
            <span class="btn icon-round"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.documents}</span><span class="desc">{s.documentsDesc}</span></span>
          </div>
          <div class="seltoolbar" id="obsToolbar">
            <span class="sel-left"><svg viewBox="0 0 24 24"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg> {s.selected2}</span>
            <span class="sel-actions">
