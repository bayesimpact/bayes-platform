---
/**
 * Animated, full-page walkthrough of the "add an admin" (Members) flow, mirroring
 * the real Studio interface (same shell, exact Lucide icons, real brand logo).
 * Shares the exact FORM of the other help-center walkthroughs — only the content
 * differs. Pass `lang="fr"` for the French copy.
 */
type Lang = "en" | "fr"
const { lang = "en" } = Astro.props as { lang?: Lang }

const STRINGS = {
  en: {
    org: "Bayes Impact Demo", studio: "Studio", agents: "Agents",
    agent1: "Bayes Assistant", conversationAgent: "Conversation Agent", extractionAgent: "Extraction Agent", formAgent: "Form Agent",
    settingsName: "Demo", settings: "Settings", evaluations: "Evaluations", analytics: "Analytics", sources: "Sources",
    documents: "Documents", webSources: "Web sources", resourceLibraries: "Resource libraries", members: "Members", admin: "Admin",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    workspace: "Workspace", conversation: "Conversation", extraction: "Extraction", form: "Form",
    timeAgo: "About 1 hour ago", create: "Create",
    newAgent: "New Agent", newAgentDesc: "An agent can perform specific tasks based on its type and configuration.",
    documentsDesc: "Enhance your agents' knowledge and capabilities by adding documents.",
    membersDesc: "Invite members to join your workspace to collaborate together.",
    reviewCampaigns: "Review campaigns", reviewDesc: "Invite testers and reviewers to evaluate an agent.",
    analyticsDesc: "View analytics for your project, including conversations, average questions per session, and more.",
    evalDesc: "Test the performance of your agents.",
    listTitle: "Members of Demo", listDesc: "Invite members to join your workspace to collaborate together.",
    searchPlaceholder: "Search by name or email…",
    inviteCardTitle: "Invite an admin",
    inviteCardDesc: "Enter the email address of the person you want to invite to join your workspace.",
    invite: "Invite", emailLabel: "Email address", emailPlaceholder: "Enter email address", add: "Add", send: "Send", cancel: "Cancel",
    inviteEmail: "sam.rivera@example.com",
    member2Name: "Jordan Lee", member2Email: "jordan.lee@example.com",
    roleOwner: "Owner", roleAdmin: "Admin",
    pendingTitle: "Pending invitations", pendingDesc: "Invitations already sent for this project.",
    invitedAgo: "Invited less than a minute ago",
    removeTitle: "Remove Jordan Lee?", removeDesc: "This will remove the member from the project. This action cannot be undone.", remove: "Remove",
    prev: "Prev", next: "Next", step: "Step",
    steps: [
      "Open Members in the left menu.",
      "Open the Invite an admin card and click Invite.",
      "Enter the person's email address, then click Add.",
      "Check the recipients, then click Send.",
      "The invitation appears under Pending invitations until it's accepted.",
      "Once accepted, the person appears as a member with a role badge.",
      "To remove a member, click the trash icon on their card, then confirm.",
      "To cancel an invitation that hasn't been accepted, delete it from Pending invitations.",
    ],
  },
  fr: {
    org: "Bayes Impact Demo", studio: "Studio", agents: "Agents",
    agent1: "Bayes Assistant", conversationAgent: "Conversation Agent", extractionAgent: "Extraction Agent", formAgent: "Form Agent",
    settingsName: "Demo", settings: "Paramètres", evaluations: "Évaluations", analytics: "Analytique", sources: "Sources",
    documents: "Documents", webSources: "Sites web", resourceLibraries: "Bibliothèques de ressources", members: "Membres", admin: "Admin",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    workspace: "Espace de travail", conversation: "Conversation", extraction: "Extraction", form: "Formulaire",
    timeAgo: "Il y a environ 1 heure", create: "Créer",
    newAgent: "Nouvel agent", newAgentDesc: "Un agent peut effectuer des tâches spécifiques selon son type et sa configuration.",
    documentsDesc: "Enrichissez les connaissances et capacités de vos agents en ajoutant des documents.",
    membersDesc: "Invitez des membres à rejoindre votre espace de travail pour collaborer ensemble.",
    reviewCampaigns: "Campagnes de revue", reviewDesc: "Invitez des testeurs et des relecteurs à évaluer un agent.",
    analyticsDesc: "Consultez les analyses de votre espace de travail : conversations, questions moyennes par session, et plus.",
    evalDesc: "Testez les performances de vos agents.",
    listTitle: "Membres de Demo", listDesc: "Invitez des membres à rejoindre votre espace de travail pour collaborer ensemble.",
    searchPlaceholder: "Rechercher par nom ou email…",
    inviteCardTitle: "Inviter un administrateur",
    inviteCardDesc: "Entrez l'adresse email de la personne que vous souhaitez inviter à rejoindre votre espace de travail.",
    invite: "Inviter", emailLabel: "Adresse email", emailPlaceholder: "Entrez l'adresse email", add: "Ajouter", send: "Envoyer", cancel: "Annuler",
    inviteEmail: "sam.rivera@example.com",
    member2Name: "Jordan Lee", member2Email: "jordan.lee@example.com",
    roleOwner: "Owner", roleAdmin: "Admin",
    pendingTitle: "Invitations en attente", pendingDesc: "Invitations déjà envoyées pour ce projet.",
    invitedAgo: "Invité il y a moins d'une minute",
    removeTitle: "Retirer Jordan Lee ?", removeDesc: "Ce membre sera retiré du projet. Cette action est irréversible.", remove: "Retirer",
    prev: "Précédent", next: "Suivant", step: "Étape",
    steps: [
      "Ouvrez Membres dans le menu de gauche.",
      "Ouvrez la carte Inviter un administrateur et cliquez sur Inviter.",
      "Saisissez l'adresse email de la personne, puis cliquez sur Ajouter.",
      "Vérifiez les destinataires, puis cliquez sur Envoyer.",
      "L'invitation apparaît dans Invitations en attente jusqu'à son acceptation.",
      "Une fois acceptée, la personne apparaît comme membre avec un badge de rôle.",
      "Pour retirer un membre, cliquez sur l'icône corbeille de sa carte, puis confirmez.",
      "Pour annuler une invitation non acceptée, supprimez-la dans Invitations en attente.",
    ],
  },
} as const

const s = STRINGS[lang]

const steps = [
  { page: "overview", sources: false, nav: "", spot: "navMembers", observe: [] },
  { page: "membersList", sources: false, nav: "members", spot: "btnInvite", observe: [] },
  { page: "inviteDialog", sources: false, nav: "members", spot: "btnAdd", observe: ["obsEmailField"] },
  { page: "inviteDialog", sources: false, nav: "members", spot: "btnSend", observe: ["obsChip"] },
  { page: "membersFull", sources: false, nav: "members", spot: "", observe: ["obsPending"] },
  { page: "membersFull", sources: false, nav: "members", spot: "", observe: ["obsRole"] },
  { page: "removeDialog", sources: false, nav: "members", spot: "btnRemoveConfirm", observe: ["obsRemoveModal"] },
  { page: "membersFull", sources: false, nav: "members", spot: "btnRevoke", observe: ["obsPending"] },
].map((step, i) => ({ ...step, text: s.steps[i] }))

const labels = { prev: s.prev, next: s.next, step: s.step }
---

<div class="msw" role="group" aria-label={s.members}>
  <div class="shell">
    <!-- Sidebar -->
    <aside class="sb">
      <div class="sb-head">
        <span class="logo"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 410.85 405.35" aria-hidden="true"><path d="M366.77,161.43H247V41.61a41.37,41.37,0,1,0-82.74,0V161.43H44.39a41.37,41.37,0,0,0,0,82.74H164.21V364A41.37,41.37,0,1,0,247,364V244.17H366.77a41.37,41.37,0,1,0,0-82.74Z"/><circle cx="205.58" cy="364.27" r="41.05"/><circle cx="369.79" cy="202.64" r="41.05"/><circle cx="41.05" cy="202.64" r="41.05"/><circle cx="205.58" cy="41.05" r="41.05"/><circle cx="205.58" cy="202.64" r="41.05"/></svg></span>
        <span class="org"><b>{s.org}</b><small>{s.studio}</small></span>
      </div>
      <div class="sb-scroll">
        <div class="grp-label">{s.agents}<span class="add"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg></span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg><span>{s.agent1}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg><span>{s.conversationAgent}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 8h8"/><path d="M7 12h10"/><path d="M7 16h6"/></svg><span>{s.extractionAgent}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M4 14h6"/><path d="M4 2h10"/><rect x="4" y="18" width="16" height="4" rx="1"/><rect x="4" y="6" width="16" height="4" rx="1"/></svg><span>{s.formAgent}</span></div>

        <div class="grp-label stack"><span class="name">{s.settingsName}</span><span>{s.settings}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/></svg><span>{s.evaluations}</span><svg class="chev" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg><span>{s.analytics}</span></div>
        <div class="navitem" id="navSources"><svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 15 21.84"/><path d="M21 5V8"/><path d="M21 12L18 17H22L19 22"/><path d="M3 12A9 3 0 0 0 14.59 14.87"/></svg><span>{s.sources}</span><svg class="chev" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></div>
        <div class="subwrap" id="sourcesSub">
          <div class="subitem"><svg viewBox="0 0 24 24"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg><span>{s.documents}</span></div>
          <div class="subitem"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg><span>{s.webSources}</span></div>
          <div class="subitem"><svg viewBox="0 0 24 24"><rect width="8" height="18" x="3" y="3" rx="1"/><path d="M7 3v18"/><path d="M20.4 18.9c.2.5-.1 1.1-.6 1.3l-1.9.7c-.5.2-1.1-.1-1.3-.6L11.1 5.1c-.2-.5.1-1.1.6-1.3l1.9-.7c.5-.2 1.1.1 1.3.6Z"/></svg><span>{s.resourceLibraries}</span></div>
        </div>
        <div class="navitem" id="navMembers"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg><span>{s.members}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg><span>{s.admin}</span></div>
      </div>
      <div class="sb-user">
        <span class="avatar">AM</span>
        <span class="who"><b>{s.userName}</b><small>{s.userEmail}</small></span>
        <span class="updown"><svg viewBox="0 0 24 24"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg></span>
      </div>
    </aside>

    <!-- Main inset -->
    <div class="inset">
      <div class="topbar">
        <span class="trig"><svg viewBox="0 0 24 24"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg></span>
      </div>
      <div class="canvas">
        <span class="fab"><svg viewBox="0 0 24 24"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg></span>

        <!-- workspace overview (step 1) -->
        <div class="page" data-page="overview" data-active="true">
          <div class="page-head plain">
            <span><span class="ttl">{s.settingsName}</span><span class="desc">{s.workspace}</span></span>
          </div>
          <div class="cards3">
            <div class="ecard"><span class="cat">{s.conversation}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg> {s.agent1}</b><p>{s.timeAgo}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><span class="cat">{s.conversation}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg> {s.conversationAgent}</b><p>{s.timeAgo}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><span class="cat">{s.extraction}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 8h8"/><path d="M7 12h10"/><path d="M7 16h6"/></svg> {s.extractionAgent}</b><p>{s.timeAgo}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><span class="cat">{s.form}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M4 14h6"/><path d="M4 2h10"/><rect x="4" y="18" width="16" height="4" rx="1"/><rect x="4" y="6" width="16" height="4" rx="1"/></svg> {s.formAgent}</b><p>{s.timeAgo}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><b>{s.newAgent}</b><p>{s.newAgentDesc}</p><span class="btn sm">{s.create} <svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg></span></div>
            <div class="ecard"><b>{s.documents}</b><p>{s.documentsDesc}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard" id="cardMembers"><b>{s.members}</b><p>{s.membersDesc}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><b>{s.reviewCampaigns}</b><p>{s.reviewDesc}</p><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><b>{s.analytics}</b><p>{s.analyticsDesc}</p><div class="bars"><i style="height:40%"></i><i style="height:65%"></i><i style="height:30%"></i><i style="height:80%"></i><i style="height:55%"></i><i style="height:70%"></i><i style="height:45%"></i><i style="height:90%"></i></div></div>
          </div>
        </div>

        <!-- members list, one member + invite card (step 2) -->
        <div class="page" data-page="membersList">
          <div class="page-head">
            <span><span class="ttl">{s.listTitle}</span><span class="desc">{s.listDesc}</span></span>
            <span class="right"><span class="searchbox"><svg viewBox="0 0 24 24"><path d="m21 21-4.34-4.34"/><circle cx="11" cy="11" r="8"/></svg> {s.searchPlaceholder}</span></span>
          </div>
          <div class="cards3">
            <div class="ecard">
              <span class="mtop"><b>{s.userName}</b><span class="rolebadge owner"><svg viewBox="0 0 24 24"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z"/><path d="M5 21h14"/></svg> {s.roleOwner}</span></span>
              <p>{s.userEmail}</p>
              <span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
            </div>
            <div class="ecard">
              <b>{s.inviteCardTitle}</b>
              <p>{s.inviteCardDesc}</p>
              <span class="btn sm" id="btnInvite"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg> {s.invite}</span>
            </div>
          </div>
        </div>

        <!-- invite dialog (steps 3 & 4) -->
        <div class="page" data-page="inviteDialog">
          <div class="scrim"></div>
          <div class="modal">
            <div class="mhead"><b>{s.inviteCardTitle}</b><p>{s.inviteCardDesc}</p></div>
            <p class="lbl">{s.emailLabel}</p>
            <div class="row" id="obsEmailField">
              <span class="input">{s.emailPlaceholder}</span>
              <span class="btn outline sm" id="btnAdd"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg> {s.add}</span>
            </div>
            <div class="chips"><span class="chip email" id="obsChip"><svg viewBox="0 0 24 24"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/><rect x="2" y="4" width="20" height="16" rx="2"/></svg> {s.inviteEmail} <svg class="chipx" viewBox="0 0 24 24"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></span></div>
            <div class="row" style="justify-content:flex-end; margin-top:1rem; gap:0.5rem"><span class="btn ghost">{s.cancel}</span><span class="btn" id="btnSend">{s.send}</span></div>
          </div>
        </div>

        <!-- members full: owner + admin + invite card + pending (steps 5, 6, 8) -->
        <div class="page" data-page="membersFull">
          <div class="page-head">
            <span><span class="ttl">{s.listTitle}</span><span class="desc">{s.listDesc}</span></span>
            <span class="right"><span class="searchbox"><svg viewBox="0 0 24 24"><path d="m21 21-4.34-4.34"/><circle cx="11" cy="11" r="8"/></svg> {s.searchPlaceholder}</span></span>
          </div>
          <div class="cards3">
            <div class="ecard">
              <span class="mtop"><b>{s.userName}</b><span class="rolebadge owner"><svg viewBox="0 0 24 24"><path d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294z"/><path d="M5 21h14"/></svg> {s.roleOwner}</span></span>
              <p>{s.userEmail}</p>
              <span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
            </div>
            <div class="ecard">
              <span class="mtop"><b>{s.member2Name}</b><span class="rolebadge admin" id="obsRole"><svg viewBox="0 0 24 24"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"/></svg> {s.roleAdmin}</span><span class="cardtrash"><svg viewBox="0 0 24 24"><path d="M10 11v6"/><path d="M14 11v6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></span></span>
              <p>{s.member2Email}</p>
              <span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
            </div>
            <div class="ecard">
              <b>{s.inviteCardTitle}</b>
              <p>{s.inviteCardDesc}</p>
              <span class="btn sm"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg> {s.invite}</span>
            </div>
          </div>
          <div class="section" id="obsPending">
            <div class="sec-head"><b>{s.pendingTitle}</b><p>{s.pendingDesc}</p></div>
            <div class="pending-card">
              <span class="pemail"><svg viewBox="0 0 24 24"><path d="m22 7-8.991 5.727a2 2 0 0 1-2.009 0L2 7"/><rect x="2" y="4" width="20" height="16" rx="2"/></svg> {s.inviteEmail}</span>
              <span class="muted-cell">{s.invitedAgo}</span>
              <span class="cardtrash" id="btnRevoke"><svg viewBox="0 0 24 24"><path d="M10 11v6"/><path d="M14 11v6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></span>
            </div>
          </div>
        </div>

        <!-- remove member confirmation (step 7) -->
        <div class="page" data-page="removeDialog">
          <div class="scrim"></div>
          <div class="modal" id="obsRemoveModal">
            <div class="mhead"><b>{s.removeTitle}</b><p>{s.removeDesc}</p></div>
            <div class="row" style="justify-content:flex-end; margin-top:1rem; gap:0.5rem"><span class="btn ghost">{s.cancel}</span><span class="btn danger" id="btnRemoveConfirm"><svg viewBox="0 0 24 24"><path d="M10 11v6"/><path d="M14 11v6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M3 6h18"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> {s.remove}</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Controls -->
  <div class="controls">
    <button class="navbtn" data-prev><svg viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg> {s.prev}</button>
    <button class="ctrl" data-playpause aria-label="Play / pause">⏸</button>
    <span class="cap"><span class="st" data-stepcount></span><span class="tx" data-captext></span></span>
    <span class="dots-nav" data-dots role="tablist" aria-label="Steps"></span>
    <button class="navbtn primary" data-next>{s.next} <svg viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></button>
  </div>
  <div class="progress"><i data-bar></i></div>
</div>

<script define:vars={{ steps, labels }}>
  const cs = document.currentScript
  const msw =
    cs && cs.previousElementSibling && cs.previousElementSibling.classList.contains("msw")
      ? cs.previousElementSibling
      : document.querySelector(".msw")
  const q = (sel) => msw.querySelector(sel)
  const pages = [...msw.querySelectorAll(".page")]
  const dotsWrap = msw.querySelector("[data-dots]")
  const bar = msw.querySelector("[data-bar]")
  const capText = msw.querySelector("[data-captext]")
  const stepCount = msw.querySelector("[data-stepcount]")
  const playPause = msw.querySelector("[data-playpause]")
  const prevBtn = msw.querySelector("[data-prev]")
  const nextBtn = msw.querySelector("[data-next]")
  const navSources = msw.querySelector("#navSources")
  const sourcesSub = msw.querySelector("#sourcesSub")
  const DUR = 6000
  let idx = 0, playing = true, timer = null

  steps.forEach((_, i) => {
    const b = document.createElement("button")
    b.className = "dotnav"; b.setAttribute("role", "tab"); b.setAttribute("aria-label", labels.step + " " + (i + 1))
    b.addEventListener("click", () => go(i)); dotsWrap.appendChild(b)
  })
  const dots = [...dotsWrap.children]

  function clearMarks() {
    msw.querySelectorAll(".spot-on").forEach((el) => el.classList.remove("spot-on"))
    msw.querySelectorAll(".observe-on").forEach((el) => el.classList.remove("observe-on"))
  }
  function render() {
    const step = steps[idx]
    pages.forEach((p) => p.setAttribute("data-active", String(p.dataset.page === step.page)))
    dots.forEach((d, i) => d.classList.toggle("on", i === idx))
    stepCount.textContent = labels.step + " " + (idx + 1) + " / " + steps.length
    capText.textContent = step.text
    navSources.classList.toggle("open", step.sources)
    sourcesSub.classList.toggle("open", step.sources)
    q("#navMembers").classList.toggle("on", step.nav === "members")

    clearMarks()
    const active = idx
    setTimeout(() => {
      if (active !== idx) return
      if (step.spot) q("#" + step.spot)?.classList.add("spot-on")
      step.observe.forEach((id) => q("#" + id)?.classList.add("observe-on"))
    }, 260)

    bar.classList.remove("run"); void bar.offsetWidth
    bar.style.setProperty("--dur", DUR + "ms")
    if (playing) bar.classList.add("run")
  }
  function schedule() { clearTimeout(timer); if (playing) timer = setTimeout(() => go(idx + 1), DUR) }
  function go(n) { idx = (n + steps.length) % steps.length; render(); schedule() }
  function setPlaying(p) {
    playing = p; playPause.textContent = p ? "⏸" : "▶"
    if (p) { bar.classList.add("run"); schedule() } else { clearTimeout(timer); bar.classList.remove("run") }
  }
  prevBtn.addEventListener("click", () => go(idx - 1))
  nextBtn.addEventListener("click", () => go(idx + 1))
  playPause.addEventListener("click", () => setPlaying(!playing))

  render(); schedule()
</script>

