---
import Icon from "./Icon.astro"
import { LOCALES } from "@/consts"
import { localeNames, useTranslations } from "@/i18n/ui"
import { getLocaleFromPath, switchLocalePath } from "@/i18n/utils"

const current = getLocaleFromPath(Astro.url.pathname)
const t = useTranslations(current)
---

<div class="relative" data-lang-switcher>
  <button
    type="button"
    class="inline-flex h-9 items-center gap-1.5 rounded-full border border-border bg-card px-3 text-sm text-foreground/80 transition-colors hover:bg-accent hover:text-foreground"
    aria-haspopup="true"
    aria-expanded="false"
    aria-label={t("lang.label")}
    data-lang-trigger
  >
    <Icon name="globe" size={16} />
    <span class="font-medium uppercase">{current}</span>
    <Icon name="chevron-down" size={14} class="opacity-60" />
  </button>
  <ul
    class="absolute right-0 z-50 mt-2 hidden min-w-44 rounded-xl border border-border bg-card p-1.5 shadow-lg"
    data-lang-menu
  >
    {
      LOCALES.map((locale) => (
        <li>
          <a
            href={switchLocalePath(Astro.url.pathname, locale)}
            aria-current={locale === current ? "true" : undefined}
            class:list={[
              "block rounded-lg px-3 py-2 text-sm transition-colors hover:bg-accent",
              locale === current
                ? "bg-secondary font-medium text-foreground"
                : "text-muted-foreground",
            ]}
          >
            {localeNames[locale]}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script is:inline>
  document.querySelectorAll("[data-lang-switcher]").forEach((root) => {
    const trigger = root.querySelector("[data-lang-trigger]")
    const menu = root.querySelector("[data-lang-menu]")
    if (!trigger || !menu) return
    const close = () => {
      menu.classList.add("hidden")
      trigger.setAttribute("aria-expanded", "false")
    }
    trigger.addEventListener("click", (event) => {
      event.stopPropagation()
      const open = menu.classList.toggle("hidden")
      trigger.setAttribute("aria-expanded", String(!open))
    })
    document.addEventListener("click", close)
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") close()
    })
  })
</script>
