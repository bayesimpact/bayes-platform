---
import Icon from "./Icon.astro"
import { useTranslations } from "@/i18n/ui"
import { getLocaleFromPath } from "@/i18n/utils"

const locale = getLocaleFromPath(Astro.url.pathname)
const t = useTranslations(locale)
---

<div class="w-full max-w-md" data-search data-locale={locale}>
  <div class="relative">
    <span class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-muted-foreground">
      <Icon name="search" size={16} />
    </span>
    <input
      type="search"
      role="combobox"
      aria-expanded="false"
      aria-controls="search-results"
      autocomplete="off"
      spellcheck="false"
      placeholder={t("search.placeholder")}
      aria-label={t("search.label")}
      class="h-9 w-full rounded-md border border-border bg-background pl-9 pr-3 text-sm outline-none transition-colors placeholder:text-muted-foreground focus:border-ring"
      data-search-input
    />
    <ul
      id="search-results"
      role="listbox"
      class="absolute left-0 right-0 z-50 mt-1 hidden max-h-80 overflow-y-auto rounded-md border border-border bg-card p-1 shadow-lg"
      data-search-results
    >
    </ul>
  </div>
</div>

<template data-search-empty>
  <li class="px-3 py-6 text-center text-sm text-muted-foreground">{t("search.noResults")}</li>
</template>

<script>
  type SearchDoc = {
    title: string
    description: string
    category: string
    href: string
    content: string
  }

  function normalize(value: string): string {
    return value
      .toLowerCase()
      .normalize("NFD")
      .replace(/\p{Diacritic}/gu, "")
  }

  function escapeHtml(value: string): string {
    return value.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;")
  }

  // Wraps the parts of `text` matching any search term in <mark>, comparing
  // case- and diacritic-insensitively while preserving the original characters.
  // A per-character index map bridges the normalized haystack back to the source.
  function highlightTerms(text: string, terms: string[]): string {
    if (terms.length === 0) return escapeHtml(text)
    let norm = ""
    const sourceIndex: number[] = []
    for (let i = 0; i < text.length; i++) {
      for (const ch of normalize(text[i])) {
        norm += ch
        sourceIndex.push(i)
      }
    }
    const ranges: Array<[number, number]> = []
    for (const term of terms) {
      if (!term) continue
      let from = 0
      while (true) {
        const at = norm.indexOf(term, from)
        if (at === -1) break
        ranges.push([sourceIndex[at], sourceIndex[at + term.length - 1] + 1])
        from = at + term.length
      }
    }
    if (ranges.length === 0) return escapeHtml(text)
    ranges.sort((a, b) => a[0] - b[0])
    const merged: Array<[number, number]> = []
    for (const [start, end] of ranges) {
      const last = merged[merged.length - 1]
      if (last && start <= last[1]) last[1] = Math.max(last[1], end)
      else merged.push([start, end])
    }
    let html = ""
    let pos = 0
    for (const [start, end] of merged) {
      html += escapeHtml(text.slice(pos, start))
      html += `<mark class="rounded-[2px] bg-[var(--gold-mark)] px-0.5 text-foreground">${escapeHtml(text.slice(start, end))}</mark>`
      pos = end
    }
    return html + escapeHtml(text.slice(pos))
  }

  function scoreDoc(doc: SearchDoc, terms: string[]): number {
    const title = normalize(doc.title)
    const haystack = normalize(`${doc.title} ${doc.description} ${doc.content}`)
    let score = 0
    for (const term of terms) {
      if (!haystack.includes(term)) return 0
      if (title.includes(term)) score += 5
      else score += 1
    }
    return score
  }

  let searchInstance = 0

  for (const root of document.querySelectorAll<HTMLElement>("[data-search]")) {
    const uid = searchInstance++
    const locale = root.dataset.locale ?? "en"
    const input = root.querySelector<HTMLInputElement>("[data-search-input]")
    const results = root.querySelector<HTMLElement>("[data-search-results]")
    const emptyTemplate = document.querySelector<HTMLTemplateElement>("[data-search-empty]")
    if (!input || !results || !emptyTemplate) continue

    let index: SearchDoc[] | null = null
    let loading = false
    let options: Array<{ el: HTMLElement; href: string }> = []
    let activeIndex = -1

    const loadIndex = async () => {
      if (index || loading) return
      loading = true
      try {
        const response = await fetch(`/${locale}/search.json`)
        index = (await response.json()) as SearchDoc[]
      } catch {
        index = []
      } finally {
        loading = false
      }
    }

    // Move the keyboard/aria highlight to option `next` (clamped; -1 = none).
    const setActive = (next: number) => {
      activeIndex = options.length === 0 ? -1 : Math.max(0, Math.min(next, options.length - 1))
      options.forEach((option, i) => {
        const on = i === activeIndex
        option.el.classList.toggle("bg-accent", on)
        option.el.setAttribute("aria-selected", on ? "true" : "false")
      })
      if (activeIndex === -1) {
        input.removeAttribute("aria-activedescendant")
      } else {
        input.setAttribute("aria-activedescendant", options[activeIndex].el.id)
        options[activeIndex].el.scrollIntoView({ block: "nearest" })
      }
    }

    const close = () => {
      results.classList.add("hidden")
      input.setAttribute("aria-expanded", "false")
      input.removeAttribute("aria-activedescendant")
      activeIndex = -1
    }

    const render = (query: string) => {
      if (!index) return
      const terms = normalize(query).split(/\s+/).filter(Boolean)
      if (terms.length === 0) {
        close()
        return
      }
      const matches = index
        .map((doc) => ({ doc, score: scoreDoc(doc, terms) }))
        .filter((entry) => entry.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 8)

      results.innerHTML = ""
      options = []
      if (matches.length === 0) {
        results.append(emptyTemplate.content.cloneNode(true))
      } else {
        matches.forEach(({ doc }, i) => {
          const li = document.createElement("li")
          li.id = `search-${uid}-opt-${i}`
          li.setAttribute("role", "option")
          li.setAttribute("aria-selected", "false")
          li.className = "scroll-my-1 rounded-sm hover:bg-accent"
          li.innerHTML = `
            <a href="${doc.href}" tabindex="-1" class="block rounded-sm px-3 py-2">
              <span class="block text-sm font-medium text-foreground">${highlightTerms(doc.title, terms)}</span>
              <span class="block truncate text-xs text-muted-foreground">${escapeHtml(doc.description)}</span>
            </a>`
          results.append(li)
          options.push({ el: li, href: doc.href })
        })
      }
      activeIndex = -1
      input.removeAttribute("aria-activedescendant")
      results.classList.remove("hidden")
      input.setAttribute("aria-expanded", "true")
    }

    input.addEventListener("focus", loadIndex)
    input.addEventListener("input", () => render(input.value))
    input.addEventListener("keydown", (event) => {
      if (results.classList.contains("hidden")) return
      if (event.key === "ArrowDown") {
        event.preventDefault()
        setActive(activeIndex + 1)
      } else if (event.key === "ArrowUp") {
        event.preventDefault()
        setActive(activeIndex <= 0 ? 0 : activeIndex - 1)
      } else if (event.key === "Enter" && activeIndex >= 0 && options[activeIndex]) {
        event.preventDefault()
        window.location.href = options[activeIndex].href
      }
    })
    document.addEventListener("click", (event) => {
      if (!root.contains(event.target as Node)) close()
    })
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        close()
        input.blur()
      }
      if (event.key === "/" && document.activeElement !== input) {
        event.preventDefault()
        input.focus()
      }
    })
  }
</script>
