    appName: "Tester", workspaces: "Workspaces", org: "Bayes Impact Demo", projectName: "Demo",
    appStudio: "Studio", appApp: "App", appEval: "Evaluation", appTest: "Test",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    myTitle: "My review campaigns", mySubtitle: "Active campaigns you've been invited to test.",
    invited: "Invited to evaluate this agent.",
    campaignName: "Agent pilot", campaignDesc: "Help us evaluate the assistant before launch.",
    agentName: "Helpful Assistant", agentType: "Conversation agent",
    greeting: "Hi! How can I help you today?",
    startSession: "Start a conversation",
    pastTitle: "Your past sessions", pastEmpty: "You haven't started any sessions yet. Your past sessions and their feedback status will appear here.",
    countOne: "1 session", countZero: "0 sessions",
    endTitle: "End-of-phase survey",
    endDesc: "When you're done testing, share an overall rating and thoughts about the experience. This is optional — your per-session feedback already counts.",
    finishParticipating: "Finish participating",
    reviewBadge: "Review campaign", endSession: "End session & give feedback",
    userMsg: "How do I reset my password?",
    botMsg: "Go to Settings → Security and click “Reset password”. You'll get an email with a link.",
    composer: "Type your message…",
