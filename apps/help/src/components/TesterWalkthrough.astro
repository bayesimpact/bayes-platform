---
/**
 * Walkthrough of the Tester app (participating in a review campaign as a tester).
 * Derived from the real components (verified, not copied blind): WorkspaceItem.tsx
 * (`goToTester` + ListChecksIcon), TesterRoute.tsx (HorizontalNavbar appName =
 * testerCampaigns:shell.title), CampaignList.tsx, CampaignLanding.tsx,
 * TesterAgentSession.tsx, TesterFeedbackModal.tsx, DynamicQuestionField.tsx,
 * SessionCard.tsx, FinishParticipatingDialog.tsx, EndOfPhaseSurveyForm.tsx. Labels
 * verbatim from tester-campaigns / actions locales (EN + FR). Uses the PRODUCT
 * (coral) palette, pinned locally. Derived 2026-07-16.
 */
type Lang = "en" | "fr"
const { lang = "en" } = Astro.props as { lang?: Lang }

const STRINGS = {
