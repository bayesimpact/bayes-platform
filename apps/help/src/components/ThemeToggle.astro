---
import Icon from "./Icon.astro"
import { useTranslations } from "@/i18n/ui"
import { getLocaleFromPath } from "@/i18n/utils"

const t = useTranslations(getLocaleFromPath(Astro.url.pathname))
---

<button
  id="theme-toggle"
  type="button"
  class="inline-flex size-9 items-center justify-center rounded-md border border-border text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
  aria-label={t("theme.toggle")}
  title={t("theme.toggle")}
>
  <Icon name="sun" class="hidden dark:block" />
  <Icon name="moon" class="block dark:hidden" />
</button>

<script is:inline>
  // Initial theme is applied in the document <head> (BaseLayout) to avoid FOUC.
  // This handler only toggles and persists the user's choice.
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const next = document.documentElement.classList.contains("dark") ? "light" : "dark"
    localStorage.setItem("help-theme", next)
    document.documentElement.classList.toggle("dark", next === "dark")
  })
</script>
