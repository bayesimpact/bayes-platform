    widgetTitle: "Widget title", logoUrl: "Logo URL", brandColor: "Brand color", brandColorValue: "#2563eb",
    save: "Save", update: "Update",
    prev: "Prev", next: "Next", step: "Step",
    steps: [
      "On the workspace overview, open the New Agent card and click Create.",
      "In the New Agent dialog, keep the Conversation type.",
      "Give your agent a name, then click Create.",
      "General: set the Name, Locale, Greeting and Instructions, then Save.",
      "Model: choose the Model and Temperature, then Save.",
      "Sources: choose the Answer source — model only, all documents, or by tags.",
      "Resource libraries: attach the libraries the agent can surface.",
      "Conversation categories: tick the categories that apply to this agent.",
      "Orchestration: add sub-agents this agent can delegate to.",
      "Embed: enable the widget, copy the snippet, set origins and branding, then Update.",
    ],
  },
  fr: {
    org: "Bayes Impact Demo", studio: "Studio", agents: "Agents",
    agent1: "Bayes Assistant", conversationAgent: "Conversation Agent", extractionAgent: "Extraction Agent", formAgent: "Form Agent",
    settingsName: "Demo", settings: "Paramètres", evaluations: "Évaluations", analytics: "Analytique", sources: "Sources",
    documents: "Documents", webSources: "Sites web", resourceLibraries: "Bibliothèques de ressources", members: "Membres", admin: "Admin",
    userName: "Alex Martin", userEmail: "alex.martin@example.com",
    conversation: "Conversation", extraction: "Extraction", form: "Formulaire",
    newAgent: "Nouvel agent", newAgentDesc: "Un agent peut effectuer des tâches spécifiques en fonction de son type et de sa configuration.",
    create: "Créer",
    dialogDesc: "Choisissez le type avant de configurer votre agent.",
    typeLabel: "Type d'agent", typeConversation: "Conversation", typeExtraction: "Extraction", typeForm: "Formulaire",
    nameLabel: "Nom", namePlaceholder: "Entrez le nom de l'agent", agentName: "Helpful Assistant",
    editTitle: "Modifier l'agent conversationnel", editDesc: "Modifier les détails de cet agent conversationnel",
    tabGeneral: "Général", tabModel: "Modèle", tabSources: "Sources", tabResources: "Bibliothèques de ressources",
    tabCategories: "Catégories de conversation", tabOrchestration: "Orchestration", tabEmbed: "Intégration",
    localeLabel: "Langue", localeValue: "EN",
    greetingLabel: "Message d'accueil", greetingValue: "Bonjour ! Comment puis-je vous aider aujourd'hui ?",
    instructionsLabel: "Instructions",
    instructionsValue: "Vous êtes un assistant utile. Répondez clairement aux questions de l'utilisateur et, si pertinent, appuyez vos réponses sur les documents de l'espace de travail.",
    modelLabel: "Modèle", modelPlaceholder: "Sélectionnez le modèle", tempLabel: "Température", tempValue: "0.7",
    answerSourceLabel: "Source de réponse", answerSourceValue: "Recherche dans les documents étiquetés",
    docTagsLabel: "Étiquettes de document", tag1: "Getting started", tag2: "Product",
    resourcesLabel: "Bibliothèques de ressources", manage: "Gérer les bibliothèques",
    resourcesDesc: "L'assistant peut proposer des ressources des bibliothèques sélectionnées lorsqu'une demande de l'utilisateur correspond au titre ou à la description d'une ressource.",
    sampleLibrary: "Getting started", addLibrary: "Add library",
    catInUse: "Les catégories déjà utilisées dans les conversations de cet agent ne peuvent pas être décochées.",
    selectAll: "Tout sélectionner", cat1: "Product", cat2: "Pricing", cat3: "Support",
    subAgentsTitle: "Sous-agents", availableTitle: "Agents conversationnels disponibles",
    toolName: "Nom de l'outil", toolDesc: "Description de l'outil", enabled: "Activé", add: "Ajouter",
    subToolName: "ask_extraction_agent", subToolDesc: "Router les demandes d'extraction de documents vers Extraction Agent.",
    embedEnabled: "Activer l'intégration", embedSnippet: "Extrait d'intégration",
    embedSnippetValue: '<script src="https://app.example.com/launcher.js" data-token="agt_1a2b3c"></script>',
    allowedOrigins: "Origines autorisées", allowedOriginsValue: "https://app.example.com",
    widgetTitle: "Titre du widget", logoUrl: "URL du logo", brandColor: "Couleur principale", brandColorValue: "#2563eb",
    save: "Enregistrer", update: "Mettre à jour",
    prev: "Précédent", next: "Suivant", step: "Étape",
    steps: [
      "Sur la vue d'ensemble de l'espace de travail, ouvrez la carte Nouvel agent et cliquez sur Créer.",
      "Dans la boîte de dialogue Nouvel agent, gardez le type Conversation.",
      "Donnez un nom à votre agent, puis cliquez sur Créer.",
      "Général : définissez le Nom, la Langue, le Message d'accueil et les Instructions, puis Enregistrez.",
      "Modèle : choisissez le Modèle et la Température, puis Enregistrez.",
      "Sources : choisissez la Source de réponse — le modèle, tous les documents, ou par étiquettes.",
      "Bibliothèques de ressources : rattachez les bibliothèques que l'agent peut proposer.",
      "Catégories de conversation : cochez les catégories qui s'appliquent à cet agent.",
      "Orchestration : ajoutez des sous-agents auxquels cet agent peut déléguer.",
      "Intégration : activez le widget, copiez l'extrait, réglez origines et marque, puis Mettez à jour.",
    ],
  },
} as const

const s = STRINGS[lang]

const TABS = [
  { key: "general", label: s.tabGeneral },
  { key: "model", label: s.tabModel },
  { key: "sources", label: s.tabSources },
  { key: "resources", label: s.tabResources },
  { key: "categories", label: s.tabCategories },
  { key: "orchestration", label: s.tabOrchestration },
  { key: "embed", label: s.tabEmbed },
]

const steps = [
  { page: "overview", spot: "btnCreate", observe: [] },
  { page: "typeDialog", spot: "btnTypeConversation", observe: ["obsTypeRow"] },
  { page: "typeDialog", spot: "btnCreateConfirm", observe: ["obsNameField"] },
  { page: "editorGeneral", spot: "", observe: ["obsGeneral"] },
  { page: "editorModel", spot: "tab-model", observe: ["obsModel"] },
  { page: "editorSources", spot: "tab-sources", observe: ["obsSources"] },
  { page: "editorResources", spot: "tab-resources", observe: ["obsResources"] },
  { page: "editorCategories", spot: "tab-categories", observe: ["obsCategories"] },
  { page: "editorOrchestration", spot: "tab-orchestration", observe: ["obsOrchestration"] },
  { page: "editorEmbed", spot: "tab-embed", observe: ["obsEmbed"] },
].map((step, i) => ({ ...step, text: s.steps[i] }))

const labels = { prev: s.prev, next: s.next, step: s.step }
---

<div class="caw" role="group" aria-label={s.newAgent}>
  <div class="shell">
    <!-- Sidebar -->
    <aside class="sb">
      <div class="sb-head">
        <span class="logo"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 410.85 405.35" aria-hidden="true"><path d="M366.77,161.43H247V41.61a41.37,41.37,0,1,0-82.74,0V161.43H44.39a41.37,41.37,0,0,0,0,82.74H164.21V364A41.37,41.37,0,1,0,247,364V244.17H366.77a41.37,41.37,0,1,0,0-82.74Z"/><circle cx="205.58" cy="364.27" r="41.05"/><circle cx="369.79" cy="202.64" r="41.05"/><circle cx="41.05" cy="202.64" r="41.05"/><circle cx="205.58" cy="41.05" r="41.05"/><circle cx="205.58" cy="202.64" r="41.05"/></svg></span>
        <span class="org"><b>{s.org}</b><small>{s.studio}</small></span>
      </div>
      <div class="sb-scroll">
        <div class="grp-label">{s.agents}<span class="add"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg></span></div>
        <div class="navitem hidden" id="navNewAgent"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg><span>{s.agentName}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg><span>{s.agent1}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg><span>{s.conversationAgent}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 8h8"/><path d="M7 12h10"/><path d="M7 16h6"/></svg><span>{s.extractionAgent}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M4 14h6"/><path d="M4 2h10"/><rect x="4" y="18" width="16" height="4" rx="1"/><rect x="4" y="6" width="16" height="4" rx="1"/></svg><span>{s.formAgent}</span></div>

        <div class="grp-label stack"><span class="name">{s.settingsName}</span><span>{s.settings}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/></svg><span>{s.evaluations}</span><svg class="chev" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/></svg><span>{s.analytics}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 15 21.84"/><path d="M21 5V8"/><path d="M21 12L18 17H22L19 22"/><path d="M3 12A9 3 0 0 0 14.59 14.87"/></svg><span>{s.sources}</span><svg class="chev" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><path d="M16 3.128a4 4 0 0 1 0 7.744"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><circle cx="9" cy="7" r="4"/></svg><span>{s.members}</span></div>
        <div class="navitem"><svg viewBox="0 0 24 24"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg><span>{s.admin}</span></div>
      </div>
      <div class="sb-user">
        <span class="avatar">AM</span>
        <span class="who"><b>{s.userName}</b><small>{s.userEmail}</small></span>
        <span class="updown"><svg viewBox="0 0 24 24"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg></span>
      </div>
    </aside>

    <!-- Main inset -->
    <div class="inset">
      <div class="topbar">
        <span class="trig"><svg viewBox="0 0 24 24"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg></span>
      </div>
      <div class="canvas">
        <span class="fab"><svg viewBox="0 0 24 24"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg></span>

        <!-- workspace overview (step 1) -->
        <div class="page" data-page="overview" data-active="true">
          <div class="page-head plain">
            <span><span class="ttl">{s.settingsName}</span><span class="desc">{s.studio}</span></span>
          </div>
          <div class="cards3">
            <div class="ecard"><span class="cat">{s.conversation}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M12 6V2H8"/><path d="m8 18-4 4V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2Z"/><path d="M9 11v2"/><path d="M15 11v2"/></svg> {s.agent1}</b><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard"><span class="cat">{s.extraction}</span><b class="ic"><svg viewBox="0 0 24 24"><path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 8h8"/><path d="M7 12h10"/><path d="M7 16h6"/></svg> {s.extractionAgent}</b><span class="arrowbtn"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span></div>
            <div class="ecard muted">
              <b>{s.newAgent}</b>
              <p>{s.newAgentDesc}</p>
              <span class="btn sm" id="btnCreate">{s.create} <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg></span>
            </div>
          </div>
        </div>

        <!-- New Agent dialog (steps 2 & 3) -->
        <div class="page" data-page="typeDialog">
          <div class="scrim"></div>
          <div class="modal">
            <div class="mhead"><b>{s.newAgent}</b><p>{s.dialogDesc}</p></div>
            <p class="lbl">{s.typeLabel}</p>
            <div class="typegrid" id="obsTypeRow">
              <span class="typebtn on" id="btnTypeConversation">{s.typeConversation}</span>
              <span class="typebtn">{s.typeExtraction}</span>
              <span class="typebtn">{s.typeForm}</span>
            </div>
            <p class="lbl">{s.nameLabel}</p>
            <div id="obsNameField"><span class="input block">{s.agentName}</span></div>
            <div class="row" style="margin-top:1rem"><span class="btn wide" id="btnCreateConfirm">{s.create}</span></div>
          </div>
        </div>

        <!-- editor: General (step 4) -->
        <div class="page" data-page="editorGeneral">
          <div class="page-head">
            <span class="backbtn"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.editTitle}</span><span class="desc">{s.editDesc}</span></span>
          </div>
          <div class="editor">
            <div class="tablist">{TABS.map((tb) => <span class:list={["tab", tb.key === "general" && "on"]}>{tb.label}</span>)}</div>
            <div class="tabbody" id="obsGeneral">
              <div class="grid2">
                <div class="fld"><p class="lbl">{s.nameLabel}</p><span class="input block">{s.agentName}</span></div>
                <div class="fld"><p class="lbl">{s.localeLabel}</p><span class="select"><span>{s.localeValue}</span><svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"/></svg></span></div>
              </div>
              <div class="fld"><p class="lbl">{s.greetingLabel}</p><span class="textarea">{s.greetingValue}</span></div>
              <div class="fld"><p class="lbl">{s.instructionsLabel}</p><span class="textarea">{s.instructionsValue}</span></div>
            </div>
            <div class="editor-foot"><span class="btn">{s.save}</span></div>
          </div>
        </div>

        <!-- editor: Model (step 5) -->
        <div class="page" data-page="editorModel">
          <div class="page-head">
            <span class="backbtn"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.editTitle}</span><span class="desc">{s.editDesc}</span></span>
          </div>
          <div class="editor">
            <div class="tablist">{TABS.map((tb) => <span class:list={["tab", tb.key === "model" && "on"]} id={tb.key === "model" ? "tab-model" : undefined}>{tb.label}</span>)}</div>
            <div class="tabbody" id="obsModel">
              <div class="grid2">
                <div class="fld"><p class="lbl">{s.modelLabel}</p><span class="select muted-select"><span>{s.modelPlaceholder}</span><svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"/></svg></span></div>
                <div class="fld"><p class="lbl">{s.tempLabel}</p><span class="input block">{s.tempValue}</span></div>
              </div>
            </div>
            <div class="editor-foot"><span class="btn">{s.save}</span></div>
          </div>
        </div>

        <!-- editor: Sources (step 6) -->
        <div class="page" data-page="editorSources">
          <div class="page-head">
            <span class="backbtn"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.editTitle}</span><span class="desc">{s.editDesc}</span></span>
          </div>
          <div class="editor">
            <div class="tablist">{TABS.map((tb) => <span class:list={["tab", tb.key === "sources" && "on"]} id={tb.key === "sources" ? "tab-sources" : undefined}>{tb.label}</span>)}</div>
            <div class="tabbody" id="obsSources">
              <div class="grid2">
                <div class="fld"><p class="lbl">{s.answerSourceLabel}</p><span class="select"><span>{s.answerSourceValue}</span><svg viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"/></svg></span></div>
              </div>
              <div class="fld">
                <p class="lbl">{s.docTagsLabel}</p>
                <div class="row">
                  <span class="badge">{s.tag1} <svg viewBox="0 0 24 24"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></span>
                  <span class="badge">{s.tag2} <svg viewBox="0 0 24 24"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></span>
                </div>
              </div>
            </div>
            <div class="editor-foot"><span class="btn">{s.save}</span></div>
          </div>
        </div>

        <!-- editor: Resource libraries (step 7) -->
        <div class="page" data-page="editorResources">
          <div class="page-head">
            <span class="backbtn"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.editTitle}</span><span class="desc">{s.editDesc}</span></span>
          </div>
          <div class="editor">
            <div class="tablist">{TABS.map((tb) => <span class:list={["tab", tb.key === "resources" && "on"]} id={tb.key === "resources" ? "tab-resources" : undefined}>{tb.label}</span>)}</div>
            <div class="tabbody" id="obsResources">
              <div class="res-head"><p class="lbl" style="margin:0">{s.resourcesLabel}</p><span class="manage">{s.manage} <svg viewBox="0 0 24 24"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg></span></div>
              <p class="hint">{s.resourcesDesc}</p>
              <div class="row">
                <span class="badge">{s.sampleLibrary} <svg viewBox="0 0 24 24"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg></span>
                <span class="btn outline sm"><svg viewBox="0 0 24 24"><path d="M5 12h14"/><path d="M12 5v14"/></svg> {s.addLibrary}</span>
              </div>
            </div>
            <div class="editor-foot"><span class="btn">{s.save}</span></div>
          </div>
        </div>

        <!-- editor: Conversation categories (step 8) -->
        <div class="page" data-page="editorCategories">
          <div class="page-head">
            <span class="backbtn"><svg viewBox="0 0 24 24"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
            <span><span class="ttl">{s.editTitle}</span><span class="desc">{s.editDesc}</span></span>
          </div>
          <div class="editor">
            <div class="tablist">{TABS.map((tb) => <span class:list={["tab", tb.key === "categories" && "on"]} id={tb.key === "categories" ? "tab-categories" : undefined}>{tb.label}</span>)}</div>
            <div class="tabbody" id="obsCategories">
              <div class="checks">
                <span class="checkrow"><span class="cbx on"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>{s.cat1}</span>
                <span class="checkrow"><span class="cbx on"><svg viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg></span>{s.cat2}</span>
                <span class="checkrow"><span class="cbx"></span>{s.cat3}</span>
              </div>
              <span class="btn outline sm" style="margin-top:0.7rem">{s.selectAll}</span>
              <p class="hint">{s.catInUse}</p>
            </div>
            <div class="editor-foot"><span class="btn">{s.save}</span></div>
          </div>
        </div>

