---
/**
 * Walkthrough of the "add a conversation agent" flow. Derived from the real
 * components (verified, not copied blind): AgentCreator.tsx (dialog),
 * AgentEditor.tsx (tab order + conditions) and each tab component
 * (AgentGeneralTab/ModelTab/SourcesTab/ResourceLibrariesTab/SessionCategoriesTab/
 * OrchestrationTab + AgentEmbedTab). Labels are verbatim from the agent /
 * resourceLibrary / actions locales (EN + FR). Depicts the fully-provisioned
 * conversation agent (all 7 tabs: categories + orchestration + embed enabled).
 * Uses the PRODUCT (coral) palette, pinned locally. Derived 2026-07-13.
 */
type Lang = "en" | "fr"
const { lang = "en" } = Astro.props as { lang?: Lang }

const STRINGS = {
