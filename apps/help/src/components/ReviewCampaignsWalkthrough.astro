  .rcw svg circle[fill="currentColor"] { fill: currentColor; }

  .rcw .shell { display: grid; grid-template-columns: 208px 1fr; height: 680px; background: var(--sidebar); color: var(--sidebar-foreground); border: 1px solid var(--sidebar-border); border-radius: 14px; overflow: hidden; box-shadow: var(--shadow); }
  .rcw .sb { display: flex; flex-direction: column; padding: 0.5rem; min-height: 0; }
