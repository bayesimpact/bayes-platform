    stDraft: "Brouillon", stActive: "Active", stClosed: "Clôturée",
    colName: "Nom", colStatus: "Statut", colMembers: "Membres", colCreated: "Créée", colUpdated: "Modifiée", colActions: "Actions",
    campaignName: "Bayes Assistant — revue T2", timeShort: "à l'instant",
    closeTitle: "Clôturer « Bayes Assistant — revue T2 » ?",
    closeDesc: "Une fois clôturée, les résultats sont agrégés et la campagne devient en lecture seule.",
    closeConfirm: "Clôturer la campagne", cancel: "Annuler",
    reportTitle: "Rapport de campagne", downloadCsv: "Télécharger le CSV",
    tMeanRating: "Note moyenne testeurs", tSessions: "Sessions", tSurveys: "Enquêtes de fin de phase",
    email1: "alice@exemple.com", email2: "bob@exemple.com",
    prev: "Précédent", next: "Suivant", step: "Étape",
    steps: [
      "Sur la vue d'ensemble de l'espace de travail, ouvrez la carte Campagnes d'évaluation.",
      "Cliquez sur Nouvelle campagne pour en créer une.",
      "Dans Général, donnez un Nom à la campagne et choisissez l'Agent ciblé.",
      "Réglez le Type de chaque question — Note, Choix unique ou Texte libre — via le menu Type.",
      "Utilisez Ajouter une question pour ajouter une question à ce groupe.",
      "Cliquez sur Créer la campagne — elle est enregistrée en Brouillon.",
      "Votre campagne apparaît dans le tableau avec le statut Brouillon.",
      "Ouvrez le brouillon et cliquez sur Activer (en haut à droite de l'éditeur), puis confirmez.",
      "Dans Participants, saisissez les e-mails, choisissez Testeur ou Relecteur, puis Envoyer les invitations.",
      "Les invités restent dans Invitations en attente jusqu'à leur acceptation.",
      "Pour la terminer, ouvrez la campagne et cliquez sur Clôturer dans l'en-tête de l'éditeur.",
