---
import Icon from "@/components/Icon.astro"
import { useTranslations } from "@/i18n/ui"
import { getLocaleFromPath } from "@/i18n/utils"
import LogoFull from "./LogoFull.astro"

const locale = getLocaleFromPath(Astro.url.pathname)
const t = useTranslations(locale)
const year = new Date().getFullYear()
const appUrl = import.meta.env.PUBLIC_APP_URL as string | undefined

// Legal entity + registered address, mirroring bayesimpact.org's footer verbatim.
const legalLine = `Association de loi 1901 (SIREN 813 821 279, FR) · 501(c)(3) (EIN 47-1102475, US) · 12 rue des Jeûneurs, 75002 Paris`

const social = [
  { name: "linkedin", label: "LinkedIn", href: "https://www.linkedin.com/company/bayes-impact/" },
  { name: "x-logo", label: "X", href: "https://x.com/bayesimpact", filled: true },
  { name: "github", label: "GitHub", href: "https://github.com/bayesimpact" },
]
---

{/* Brand footer — near-black surface, laid out exactly like bayesimpact.org's footer:
    an upper band (socials left · links right) over a main band (logo + legal line). */}
<footer class="relative mt-16 overflow-hidden bg-[#0e0e13] text-white/75">
  <div
    class="pointer-events-none absolute inset-0 opacity-70"
    style="background: radial-gradient(120% 90% at 50% 120%, rgba(255,132,0,0.10), transparent 60%);"
  >
  </div>

  <div class="relative mx-auto max-w-[1360px] px-6 pt-14 sm:px-10">
    {/* Upper band — socials left, navigation links right (newsletter's slot). */}
    <div
      class="flex flex-col items-center gap-4 border-y border-white/12 py-6 sm:flex-row sm:justify-between sm:gap-6"
    >
      <div class="flex items-center gap-6">
        {
          social.map((entry) => (
            <a
              class="flex items-center justify-center text-white/70 opacity-70 transition-opacity hover:opacity-100"
              href={entry.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={entry.label}
            >
              <Icon name={entry.name} size={entry.filled ? 18 : 20} filled={entry.filled} />
            </a>
          ))
        }
      </div>

      <div class="flex items-center gap-4 text-sm text-white/70 sm:gap-5">
        {
          appUrl && (
            <a class="transition-colors hover:text-white" href={appUrl}>
              {t("nav.backToApp")}
            </a>
          )
        }
        {appUrl && <span class="text-white/25">·</span>}
        <a
          class="transition-colors hover:text-white"
          href="https://www.bayesimpact.org"
          target="_blank"
          rel="noopener noreferrer"
        >
          bayesimpact.org
        </a>
      </div>
    </div>

    {/* Main band — logo (+ tagline) stacked above the legal line. */}
    <div class="grid gap-10 pb-16 pt-14">
      <div class="flex flex-col items-start gap-4">
        <LogoFull class="h-7 w-auto text-white" />
        <p class="max-w-sm text-sm leading-relaxed text-white/55">{t("site.tagline")}</p>
      </div>

      <p class="text-xs leading-relaxed text-white/45">
        © {year} Bayes Impact — {legalLine} —{" "}
        <a
          class="underline underline-offset-[3px] opacity-80 transition-opacity hover:opacity-100"
          href="https://www.bayesimpact.org/legal-notices/"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t("footer.legalNotice")}
        </a>
        {" · "}
        <a
          class="underline underline-offset-[3px] opacity-80 transition-opacity hover:opacity-100"
          href="https://www.bayesimpact.org/privacy-policy/"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t("footer.privacyPolicy")}
        </a>
      </p>
    </div>
  </div>
</footer>
