# URL of the main application, shown as a "Back to the app" link in the header.
# Optional — the link is hidden when unset.
PUBLIC_APP_URL=https://app.bayesimpact.org

# --- Per-tenant configuration (one build/deployment per tenant) ---
# All values are optional. Unset, the site runs its LOCAL-DEV defaults (purple brand,
# so a local build is never mistaken for a real tenant). CI overrides them per tenant.

# Internal tenant slug (e.g. "connect").
TENANT=connect
# Canonical URL of this help-center instance (used for sitemap / og / canonical).
SITE_URL=https://help.bayesimpact.org
# Displayed site title / brand name (header, footer, page <title>).
SITE_TITLE=Bayes Platform Help Center

# Brand colour of the walkthrough animations, so the help center matches the platform
# it was opened from. Mirrors the platform's own mechanism (apps/web/src/theme.css):
# a single `--primary`, purple by default in local dev, overridden per tenant at build.
# CI passes the tenant's `--primary` (from infra `assets/{tenant}/theme.css`) here.
# BRAND_PRIMARY=oklch(74.137% 0.13055 37.323)
# The logo mark colour defaults to BRAND_PRIMARY; set this only for a different logo colour.
# BRAND_LOGO_COLOR=#f18c6e

# --- Reserved for future chrome theming (documented, NOT wired yet) ---
# Brand name shown in the site chrome — currently derived from SITE_TITLE.
# BRAND_NAME=Bayes Impact
# Path to the brand logo SVG served from /public (e.g. /brands/connect.svg).
# BRAND_LOGO=/favicon.svg
