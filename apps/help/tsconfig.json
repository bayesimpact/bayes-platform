{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"],
    "strictNullChecks": true,
    "allowJs": true
  },
  "include": [".astro/types.d.ts", "src/**/*", "astro.config.ts"],
  "exclude": ["node_modules", "dist"]
}
