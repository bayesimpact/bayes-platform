TZ='UTC'

LOG_LEVEL=debug # fatal | error | warn | log | debug | verbose (default: log)
OTEL_CONSOLE_EXPORT=false # print OTEL spans to stdout (default: false)
DIAGNOSTICS_SECRET=change-me # secret path for /diagnostics/<secret>/test-error

GOOGLE_APPLICATION_CREDENTIALS=../../dontsave/caseai-connect-XXX.json

LANGFUSE_SK=XXX
LANGFUSE_PK=XXX
LANGFUSE_BASE_URL=XXX

#Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=connect_admin
DATABASE_PASSWORD=passpass
DATABASE_NAME=connect

# Auth0
AUTH0_ISSUER_URL=https://your-tenant.auth0.com/
AUTH0_AUDIENCE=https://your-tenant.auth0.com/api/v2/

# Auth0 Invitations (see docs/specs/auth0-invitation-sending.md)
AUTH0_ORGANIZATION_ID=org_XXX
AUTH0_CLIENT_ID=XXX
AUTH0_M2M_CLIENT_ID=XXX
AUTH0_M2M_CLIENT_SECRET=XXX

# DB used to authenticate users via email/password
AUTH0_DB_CONNECTION_NAME=Username-Password-Authentication

# File Storage Config
LOCAL_STORAGE_SERVER_BASE_URL=https://connect.localhost:3000
# GCS_STORAGE_BUCKET_NAME=test-connect-file-storage
# GCS_CREDENTIALS=../../../dontsave/bayes-agents-xx.json

# Bull Board (BullMQ dashboard) — Auth0 browser login (express-openid-connect). Create a Regular Web Application in Auth0.
# BULL_BOARD_ENABLED=false
# BULL_BOARD_BASE_URL=https://connect.localhost:3000
# BULL_BOARD_ROUTE=internal/bull-board
# BULL_BOARD_AUTH0_CLIENT_ID=XXX
# BULL_BOARD_AUTH0_CLIENT_SECRET=XXX
# BULL_BOARD_AUTH0_ORGANIZATION=org_XXX
# BULL_BOARD_OIDC_SECRET=at-least-8-chars-random
BULL_BOARD_ALLOWED_EMAIL_DOMAIN=bayesimpact.org
# Callback / logout URLs to register on that Auth0 app: {BULL_BOARD_BASE_URL}/{BULL_BOARD_ROUTE}/oauth/callback (and same prefix for login/logout routes)

# Document Embeddings
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=europe-west1
DOCUMENT_EMBEDDING_MODELS=gemini-embedding-001

# Workers — mark queued/processing documents failed if unchanged longer than threshold (seconds). Sweep interval (seconds) must also be set. No defaults in app code.
DOCUMENT_EMBEDDING_STUCK_THRESHOLD_SECONDS=86400
DOCUMENT_EMBEDDING_STUCK_SWEEP_INTERVAL_SECONDS=900
# Optional override for the maintenance queue name (default: document-embeddings-stuck-sweep)
# DOCUMENT_EMBEDDINGS_STUCK_SWEEP_QUEUE_NAME=document-embeddings-stuck-sweep

# MCP Server Encryption (64-char hex, 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_ENCRYPTION_KEY=your-64-char-hex-key-here

# Organization creation — email domain allowed to create organizations (e.g. @example.com)
ORGANIZATION_CREATOR_EMAIL_DOMAIN=@example.com

# Backoffice — email domain whose users can reach /backoffice routes (scoped to the orgs/projects/agents they admin)
BACKOFFICE_AUTHORIZED_DOMAIN=@example.com
# Backoffice — comma-separated emails of "super admins" who see and manage all orgs, projects, and users
BACKOFFICE_AUTHORIZED_EMAILS=admin@example.com,ops@example.com

# CORS — comma-separated list of allowed frontend origins.
FRONTEND_URL=https://connect.localhost:5173,https://connect.localhost:5174
