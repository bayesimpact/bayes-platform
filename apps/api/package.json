{
  "name": "@caseai-connect/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "dev:workers-main": "BULL_BOARD_ENABLED=false nest start --entryFile workers-main --watch",
    "dev:workers-main-windows": "tsc -b ../../packages/api-contracts && nest start --entryFile workers-main --watch",
    "build": "nest build",
    "build:test": "tsc -p tsconfig.build-test.json",
    "start": "nest start",
    "start:workers-main": "node dist/workers-main",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "check:circular": "node scripts/check-circular.mjs",
    "check:circular:baseline": "node scripts/check-circular.mjs --write",
    "check:deps": "depcruise src --ignore-known .dependency-cruiser-known-violations.json",
    "check:deps:baseline": "depcruise src --output-type baseline --output-to .dependency-cruiser-known-violations.json",
    "check:boundaries": "npm run check:circular && npm run check:deps",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --colors --runInBand",
    "test:workers:prepare": "ts-node -r tsconfig-paths/register src/scripts/prepare-test-worker-dbs.ts",
    "test:workers:cleanup": "ts-node -r tsconfig-paths/register src/scripts/cleanup-test-worker-dbs.ts",
    "test:parallel": "ts-node -r tsconfig-paths/register src/scripts/run-test-parallel.ts",
    "test:services:parallel": "npm run test:parallel -- --testPathPattern=\\.service\\.spec\\.ts$",
    "migration:generate": "node -r tsconfig-paths/register -r ts-node/register ../../node_modules/typeorm/cli.js migration:generate src/migrations/pending/dontsave-mig -d src/config/typeorm.ts",
    "migration:create": "node -r tsconfig-paths/register -r ts-node/register ../../node_modules/typeorm/cli.js migration:create ./src/migrations/mig",
    "migration:run": "node -r tsconfig-paths/register -r ts-node/register ../../node_modules/typeorm/cli.js migration:run -d src/config/typeorm.ts",
    "migration:revert": "node -r tsconfig-paths/register -r ts-node/register ../../node_modules/typeorm/cli.js migration:revert -d src/config/typeorm.ts",
    "migration:show": "node -r tsconfig-paths/register -r ts-node/register ../../node_modules/typeorm/cli.js migration:show -d src/config/typeorm.ts",
    "migration:test:run": "node -r tsconfig-paths/register -r ts-node/register ../../node_modules/typeorm/cli.js migration:run -d src/config/typeorm.test.ts",
    "migration:test:revert": "node -r tsconfig-paths/register -r ts-node/register ../../node_modules/typeorm/cli.js migration:revert -d src/config/typeorm.test.ts",
    "migration:test:show": "node -r tsconfig-paths/register -r ts-node/register ../../node_modules/typeorm/cli.js migration:show -d src/config/typeorm.test.ts",
    "requeue:document-embeddings": "ts-node -r tsconfig-paths/register src/scripts/requeue-document-embeddings.ts",
    "requeue:evaluation-extraction-runs": "ts-node -r tsconfig-paths/register src/scripts/requeue-evaluation-extraction-runs.ts",
    "seed:mcp-preset": "ts-node -r tsconfig-paths/register src/scripts/seed-mcp-preset.ts",
    "seed:review-campaign-tester": "ts-node -r tsconfig-paths/register src/scripts/seed-review-campaign-tester.ts",
    "mcp:link-to-project": "ts-node -r tsconfig-paths/register src/scripts/link-mcp-to-project.ts",
    "agent:set-session-categories": "ts-node -r tsconfig-paths/register src/scripts/set-agent-session-categories.ts",
    "project:set-agent-session-categories": "ts-node -r tsconfig-paths/register src/scripts/set-project-agent-session-categories.ts",
    "invite:organization-owners": "ts-node -r tsconfig-paths/register src/scripts/invite-organization-owners.ts",
    "invite:manage": "ts-node -r tsconfig-paths/register src/scripts/manage-invitations.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.13",
    "@ai-sdk/google-vertex": "^4.0.142",
    "@ai-sdk/mcp": "^1.0.30",
    "@bull-board/api": "^6.21.3",
    "@bull-board/express": "^6.21.3",
    "@bull-board/nestjs": "^6.21.3",
    "@bull-board/ui": "^6.21.3",
    "@caseai-connect/api-contracts": "*",
    "@google-cloud/aiplatform": "^6.5.0",
    "@google-cloud/opentelemetry-cloud-monitoring-exporter": "^0.21.0",
    "@google-cloud/opentelemetry-cloud-trace-exporter": "^3.0.0",
    "@google-cloud/storage": "^7.18.0",
    "@google/genai": "^1.21.0",
    "@llamaindex/readers": "^3.1.22",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/typeorm": "^11.0.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.60.0",
    "@opentelemetry/instrumentation-pg": "^0.66.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@spider-cloud/spider-client": "^0.2.0",
    "ai": "^6.0.87",
    "axios": "^1.12.2",
    "bullmq": "^5.70.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "express-openid-connect": "^2.20.2",
    "jwks-rsa": "^3.2.0",
    "langfuse": "^3.38.6",
    "langfuse-core-v2": "npm:langfuse-core@3.16.2",
    "langfuse-v2": "npm:langfuse@3.16.2",
    "llamaindex": "^0.12.1",
    "mammoth": "^1.11.0",
    "papaparse": "^5.5.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "pgvector": "^0.2.1",
    "qs": "^6.14.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "sql-highlight": "^6.1.0",
    "typeorm": "^0.3.29",
    "undici": "^8.7.0",
    "uuid": "^11.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@repo/jest-config": "*",
    "@repo/typescript-config": "*",
    "@types/express": "^4.17.17",
    "@types/node": "^22.10.7",
    "@types/papaparse": "^5.5.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.0",
    "dependency-cruiser": "^17.3.10",
    "fishery": "^2.4.0",
    "jest": "^29.7.0",
    "madge": "^8.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.5.4"
  },
  "exports": {
    "./*": "./src/exports/*.ts"
  }
}
