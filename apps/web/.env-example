VITE_API_URL=http://localhost:3000
VITE_AGENT_EMBED_URL=https://connect.localhost:5175
VITE_API_TIMEOUT_MS=10000

# Vite dev / preview server ports (defaults 5173 / 5174). Override to run
# several frontends side by side.
FRONT_PORT=5173
FRONT_PREVIEW_PORT=5174
VITE_APP_TITLE=AgentStudio
VITE_PREMIUM_EMAIL_DOMAIN=@bayesimpact.org
VITE_HELP_CENTER_URL=https://bayesimpact.notion.site/Bayes-Platform-Help-Center-33c7d19cc82580b5a0c8e53befb0dd59
# Optional: embed token of the help agent to display an in-platform chat bubble (uses VITE_AGENT_EMBED_URL as the launcher base URL)
#VITE_HELP_AGENT_EMBED_TOKEN=your-embed-token-here
#VITE_HELP_AGENT_EMBED_COLOR=#2563eb
# Optional: hint bubble shown next to the launcher button on load and on hover.
# Plain string (all languages) or JSON object keyed by locale for multilingual installs.
#VITE_HELP_AGENT_EMBED_HINT=Need help? Ask us!
#VITE_HELP_AGENT_EMBED_HINT={"en":"Need help? Ask us!","fr":"Besoin d'aide ?"}

# Auth0
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=XXX
VITE_AUTH0_AUDIENCE=https://your-tenant.auth0.com/api/v2/
VITE_AUTH0_ORGANIZATION_ID=org_XXXX

# Optional: Base64-encoded default prompts and schemas for agents
#VITE_DEFAULT_CONVERSATION_AGENT_PROMPT=BASE64_ENCODED_STRING
#VITE_DEFAULT_FORM_AGENT_PROMPT=BASE64_ENCODED_STRING
#VITE_DEFAULT_FORM_AGENT_SCHEMA=BASE64_ENCODED_STRING
#VITE_DEFAULT_EXTRACTION_AGENT_PROMPT=BASE64_ENCODED_STRING
#VITE_DEFAULT_EXTRACTION_AGENT_SCHEMA=BASE64_ENCODED_STRING